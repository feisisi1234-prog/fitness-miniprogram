/* 3D模型查看器样式 */
.model-viewer-container {
  position: relative;
  width: 100%;
  height: 800rpx;
  background: linear-gradient(135deg, #f5f7fa, #e8eef5);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.webgl-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

/* 加载遮罩 */
.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.loading-progress {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #07c160;
}

/* 控制按钮 */
.controls {
  position: absolute;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  padding: 20rpx;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(10rpx);
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx 25rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.control-btn:active {
  background: rgba(7, 193, 96, 0.1);
  transform: scale(0.95);
}

.control-icon {
  font-size: 40rpx;
  margin-bottom: 5rpx;
}

.control-label {
  font-size: 22rpx;
  color: #666;
}

/* 操作提示 */
.hint {
  position: absolute;
  top: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.7);
  color: #ffffff;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  animation: fadeInOut 3s ease-in-out infinite;
  z-index: 5;
}

.hint-text {
  white-space: nowrap;
}

@keyframes fadeInOut {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}
