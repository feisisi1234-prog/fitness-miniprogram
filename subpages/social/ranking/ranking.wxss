/* subpages/social/ranking/ranking.wxss */
.ranking-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #fef3f2 100%);
  padding-bottom: 40rpx;
}

/* 顶部切换 */
.tabs-container {
  background: #ffffff;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.tab-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #ffffff;
}

.metric-tabs {
  display: flex;
  gap: 16rpx;
}

.metric-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.metric-item.active {
  background: rgba(16, 185, 129, 0.1);
}

.metric-icon {
  width: 32rpx;
  height: 32rpx;
}

.metric-item.active .metric-icon {
  filter: brightness(0) saturate(100%) invert(64%) sepia(56%) saturate(1614%) hue-rotate(115deg) brightness(96%) contrast(91%);
}

.metric-text {
  font-size: 26rpx;
  color: #666;
}

.metric-item.active .metric-text {
  color: #10b981;
  font-weight: 600;
}

/* 我的排名 */
.my-ranking {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 32rpx;
  margin: 0 32rpx 24rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.my-rank-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.rank-number {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
}

.rank-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
}

.my-rank-stats {
  flex: 1;
}

.rank-stat {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.stat-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
}

.stat-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 排行榜列表 */
.ranking-list {
  padding: 0 32rpx;
}

/* 前三名 */
.top-three {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
  padding: 32rpx 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

.top-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  padding: 24rpx 16rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.top-item.first {
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  transform: scale(1.1);
  z-index: 3;
}

.top-item.second {
  background: linear-gradient(135deg, #94a3b8 0%, #64748b 100%);
  z-index: 2;
}

.top-item.third {
  background: linear-gradient(135deg, #fb923c 0%, #ea580c 100%);
  z-index: 1;
}

.crown {
  position: absolute;
  top: -32rpx;
  font-size: 48rpx;
  animation: float 2s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.medal-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
}

.medal-badge.gold {
  background: rgba(255, 255, 255, 0.3);
}

.medal-badge.silver {
  background: rgba(255, 255, 255, 0.3);
}

.medal-badge.bronze {
  background: rgba(255, 255, 255, 0.3);
}

.top-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.top-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
}

.top-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 其他排名 */
.other-ranks {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  transition: all 0.3s;
}

.rank-item.is-me {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(5, 150, 105, 0.1) 100%);
  border: 2rpx solid #10b981;
}

.rank-number {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #666;
  background: #f5f5f5;
  border-radius: 50%;
}

.rank-item.is-me .rank-number {
  background: #10b981;
  color: #ffffff;
}

.rank-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.rank-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rank-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.rank-level {
  font-size: 24rpx;
  color: #10b981;
}

.rank-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #10b981;
}


/* 排行榜用户ID */
.rank-id {
  font-size: 22rpx;
  color: #999;
  font-family: 'Courier New', monospace;
  letter-spacing: 0.5rpx;
  margin-bottom: 4rpx;
}
