/* subpages/social/friends/friends.wxss */
.friends-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #fef3f2 100%);
  padding-bottom: 40rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 24rpx 32rpx;
  background: #ffffff;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 48rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.clear-btn {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 24rpx;
}

/* 搜索结果 */
.search-results {
  margin-top: 24rpx;
}

.result-header {
  padding: 24rpx 32rpx 16rpx;
  font-size: 28rpx;
  color: #666;
}

.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.result-list {
  background: #ffffff;
  border-radius: 24rpx;
  margin: 0 32rpx;
  overflow: hidden;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.user-level {
  font-size: 24rpx;
  color: #10b981;
}

.add-btn {
  padding: 12rpx 32rpx;
  background: #10b981;
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 28rpx;
}

/* 好友列表 */
.friends-content {
  padding: 24rpx 32rpx;
}

.friends-header {
  margin-bottom: 24rpx;
}

.friends-count {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.empty-friends {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.friends-list {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.friend-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.3s;
}

.friend-item:last-child {
  border-bottom: none;
}

.friend-item:active {
  background: #f9f9f9;
}

.friend-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.friend-info {
  flex: 1;
}

.friend-name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.friend-stats {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.stat-item {
  color: #666;
}

.stat-divider {
  margin: 0 12rpx;
  color: #ddd;
}

.friend-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.continuous-days {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 12rpx;
}

.days-number {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1;
}

.days-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.delete-btn {
  font-size: 24rpx;
  color: #ef4444;
  padding: 4rpx 12rpx;
}


/* 用户ID和好友ID */
.user-id,
.friend-id {
  font-size: 22rpx;
  color: #999;
  font-family: 'Courier New', monospace;
  letter-spacing: 0.5rpx;
  margin-bottom: 4rpx;
}

.friend-id {
  margin-bottom: 8rpx;
}
