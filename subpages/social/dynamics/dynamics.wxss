/* subpages/social/dynamics/dynamics.wxss */
.dynamics-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #fef3f2 100%);
  padding: 24rpx 32rpx 40rpx;
}

/* 发布按钮 */
.publish-btn-container {
  margin-bottom: 24rpx;
}

.publish-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.3);
  transition: all 0.3s;
}

.publish-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(16, 185, 129, 0.3);
}

.publish-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
}

.publish-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 动态列表 */
.dynamics-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.dynamic-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.dynamic-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.dynamic-time {
  font-size: 24rpx;
  color: #999;
}

.dynamic-body {
  margin-bottom: 24rpx;
}

.dynamic-content {
  font-size: 30rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  margin-bottom: 20rpx;
}

.training-info {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
}

.training-stat {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(5, 150, 105, 0.1) 100%);
  border-radius: 16rpx;
}

.stat-icon {
  width: 32rpx;
  height: 32rpx;
}

.stat-text {
  font-size: 26rpx;
  color: #10b981;
  font-weight: 500;
}

.achievement-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.achievement-icon {
  font-size: 48rpx;
}

.dynamic-footer {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  border-radius: 48rpx;
  background: #f5f5f5;
  transition: all 0.3s;
}

.action-btn.liked {
  background: rgba(245, 158, 11, 0.1);
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
  transition: all 0.3s;
}

.action-btn.liked .action-icon {
  filter: brightness(0) saturate(100%) invert(64%) sepia(98%) saturate(1614%) hue-rotate(359deg) brightness(102%) contrast(101%);
}

.action-text {
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.action-btn.liked .action-text {
  color: #f59e0b;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 32rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.3;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}


/* 图片内容 */
.dynamic-image-box {
  margin-top: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.dynamic-image-box.single {
  max-height: 600rpx;
}

.dynamic-image {
  width: 100%;
  height: 400rpx;
  display: block;
}

/* 多图网格 */
.dynamic-images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-top: 20rpx;
}

.grid-image {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
}

.grid-image.single {
  grid-column: span 3;
  height: 400rpx;
}

/* 标签 */
.dynamic-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tag-item {
  padding: 8rpx 20rpx;
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
  font-size: 24rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

/* 打卡时间 */
.checkin-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 12rpx 20rpx;
  background: rgba(59, 130, 246, 0.1);
  border-radius: 12rpx;
  width: fit-content;
}

.time-icon {
  width: 28rpx;
  height: 28rpx;
}

.time-text {
  font-size: 24rpx;
  color: #3b82f6;
  font-weight: 500;
}

/* 评论区 */
.comments-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.comments-header {
  margin-bottom: 16rpx;
}

.comments-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.comments-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
}

.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.comment-user {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 600;
}

.comment-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 评论输入弹窗 */
.comment-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.comment-modal-content {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

.modal-body {
  position: relative;
}

.comment-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.cancel-btn,
.submit-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.submit-btn {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
}


/* 发布动态弹窗 */
.publish-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1001;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.publish-modal-content {
  position: relative;
  width: 90%;
  max-height: 85vh;
  background: #ffffff;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  animation: scaleIn 0.3s ease-out;
  z-index: 1002;
  overflow: hidden;
}

@keyframes scaleIn {
  from {
    transform: scale(0.9) translateY(-50%);
    opacity: 0;
  }
  to {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
}

.publish-modal-content .modal-header {
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.publish-modal-content .modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx;
}

.publish-modal-content .modal-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.publish-textarea {
  width: 100%;
  min-height: 240rpx;
  max-height: 400rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.textarea-wrapper {
  margin-bottom: 12rpx;
}

/* 图片选择区域 */
.image-section {
  margin-top: 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-image-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  z-index: 10;
}

.add-image-btn {
  width: 100%;
  padding-bottom: 100%;
  position: relative;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx dashed #d0d0d0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-image-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -70%);
  width: 56rpx;
  height: 56rpx;
  opacity: 0.4;
}

.add-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, 40%);
  font-size: 22rpx;
  color: #999;
}
