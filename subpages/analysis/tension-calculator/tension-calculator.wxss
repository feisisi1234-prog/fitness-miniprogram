/* 统一清新活力风格 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #fef3f2 100%);
  padding: 100rpx 30rpx 40rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.bg-decoration {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

.float-ball {
  position: absolute;
  border-radius: 50%;
  opacity: 0.6;
  animation: float 6s ease-in-out infinite;
}

.ball-1 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(16, 185, 129, 0.3) 0%, transparent 70%);
  top: -100rpx;
  right: -100rpx;
}

.ball-2 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(251, 146, 60, 0.2) 0%, transparent 70%);
  bottom: -150rpx;
  left: -150rpx;
  animation-delay: 2s;
}

@keyframes float {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(20rpx, -20rpx) scale(1.1); }
}

/* 返回按钮 */
.back-btn {
  position: fixed;
  top: 60rpx;
  left: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.back-btn:active {
  transform: scale(0.95);
}

.back-icon {
  font-size: 40rpx;
  color: #10b981;
  font-weight: bold;
}

/* 动作标题 */
.exercise-header {
  background: linear-gradient(135deg, #ffffff 0%, #f8fffe 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(16, 185, 129, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.exercise-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.muscle-tag {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}

/* 通用区块 */
.formula-section,
.data-section,
.custom-calculation {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 1;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
  filter: brightness(0) saturate(100%) invert(58%) sepia(89%) saturate(449%) hue-rotate(101deg) brightness(95%) contrast(92%);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

/* 公式区域 */
.formula-box {
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #10b981;
}

.formula-main {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #047857;
  text-align: center;
  margin-bottom: 16rpx;
  font-family: 'Courier New', monospace;
}

.formula-detail {
  display: block;
  font-size: 26rpx;
  color: #059669;
  text-align: center;
  margin-bottom: 8rpx;
}

.formula-simplified {
  background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
  border-radius: 16rpx;
  padding: 20rpx;
  border-left: 6rpx solid #fb923c;
}

.formula-label {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #ea580c;
  margin-bottom: 8rpx;
}

.formula-content {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #9a3412;
  margin-bottom: 8rpx;
}

.formula-note {
  display: block;
  font-size: 24rpx;
  color: #9a3412;
}

/* 数据表格 */
.data-table {
  margin-bottom: 20rpx;
}

.table-header {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 12rpx 12rpx 0 0;
  padding: 20rpx 0;
}

.header-cell {
  font-size: 26rpx;
  font-weight: bold;
  color: #ffffff;
  text-align: center;
}

.table-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.table-row:last-child {
  border-bottom: none;
}

.table-cell {
  font-size: 28rpx;
  color: #333333;
  text-align: center;
}

.table-cell.highlight {
  font-weight: bold;
  color: #10b981;
}

.training-tip {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fef3f2 0%, #fee2e2 100%);
  border-radius: 12rpx;
  padding: 20rpx;
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  filter: brightness(0) saturate(100%) invert(48%) sepia(79%) saturate(2476%) hue-rotate(346deg) brightness(98%) contrast(97%);
}

.tip-text {
  font-size: 26rpx;
  color: #dc2626;
  flex: 1;
}

/* 自定义计算表单 */
.calc-form {
  margin-bottom: 20rpx;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.weight-input {
  width: 100%;
  height: 88rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  border: 2rpx solid #e0e0e0;
}

.weight-input:focus {
  border-color: #10b981;
  background: #ffffff;
}

.toggle-advanced {
  text-align: center;
  padding: 16rpx 0;
  margin-bottom: 24rpx;
}

.toggle-text {
  font-size: 26rpx;
  color: #10b981;
  text-decoration: underline;
}

.calculate-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
  border: none;
}

.calculate-btn:active {
  transform: scale(0.98);
}

.calculate-btn::after {
  border: none;
}

.btn-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 计算结果 */
.result-section {
  margin-top: 30rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.result-content {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.result-item {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid rgba(16, 185, 129, 0.2);
}

.result-item.primary {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.3);
}

.result-label {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.result-item.primary .result-label {
  color: rgba(255, 255, 255, 0.9);
}

.result-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #10b981;
  margin-bottom: 4rpx;
}

.result-item.primary .result-value {
  color: #ffffff;
}

.result-unit {
  font-size: 24rpx;
  color: #999999;
}

.result-item.primary .result-unit {
  color: rgba(255, 255, 255, 0.8);
}

.result-note {
  background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.note-text {
  font-size: 26rpx;
  color: #9a3412;
}
