/* 统一清新活力风格 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #fef3f2 100%);
  padding: 100rpx 30rpx 40rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.bg-decoration {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

.float-ball {
  position: absolute;
  border-radius: 50%;
  opacity: 0.6;
  animation: float 6s ease-in-out infinite;
}

.ball-1 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(16, 185, 129, 0.3) 0%, transparent 70%);
  top: -100rpx;
  right: -100rpx;
  animation-delay: 0s;
}

.ball-2 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(251, 146, 60, 0.2) 0%, transparent 70%);
  bottom: -150rpx;
  left: -150rpx;
  animation-delay: 2s;
}

@keyframes float {
  0%, 100% {
    transform: translate(0, 0) scale(1);
  }
  50% {
    transform: translate(20rpx, -20rpx) scale(1.1);
  }
}

/* 返回按钮 */
.back-btn {
  position: fixed;
  top: 60rpx;
  left: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
  transition: all 0.3s ease;
}

.back-btn:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 1);
}

.back-icon {
  font-size: 40rpx;
  color: #10b981;
  font-weight: bold;
}

/* 动作标题 */
.action-header {
  background: linear-gradient(135deg, #ffffff 0%, #f8fffe 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(16, 185, 129, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
  border: 2rpx solid rgba(16, 185, 129, 0.1);
}

.action-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.action-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 16rpx;
  text-align: center;
}

.muscle-tag {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 动作示意图 */
.action-image-section {
  margin-bottom: 30rpx;
  position: relative;
  z-index: 1;
}

.image-placeholder {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0f9ff 100%);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid rgba(16, 185, 129, 0.1);
}

.placeholder-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999999;
}

/* 详情区块 */
.detail-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 1;
  border: 2rpx solid rgba(16, 185, 129, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
  filter: brightness(0) saturate(100%) invert(58%) sepia(89%) saturate(449%) hue-rotate(101deg) brightness(95%) contrast(92%);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.section-content {
  padding: 10rpx 0;
}

.content-text {
  font-size: 28rpx;
  line-height: 48rpx;
  color: #333333;
  text-align: justify;
}

.tips-content {
  background: linear-gradient(135deg, #fff7ed 0%, #fef3f2 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  border-left: 6rpx solid #fb923c;
}

.tips-text {
  font-size: 28rpx;
  line-height: 48rpx;
  color: #ea580c;
  font-weight: 500;
}

/* 操作按钮 */
.action-buttons {
  margin-top: 40rpx;
  padding: 20rpx 0;
  position: relative;
  z-index: 1;
}

.start-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
  border: none;
  transition: all 0.3s ease;
}

.start-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.4);
}

.start-btn::after {
  border: none;
}

.btn-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 2rpx;
}
