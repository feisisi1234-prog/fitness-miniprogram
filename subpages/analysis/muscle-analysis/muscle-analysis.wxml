<view class="container">
  <!-- 标签页切换 -->
  <view class="tabs">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">肌纤维走向</view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">肌肉张力计算</view>
  </view>

  <!-- 肌纤维走向页面 -->
  <view class="tab-content" wx:if="{{currentTab === 0}}">
    <!-- 视频展示区域 -->
    <view class="model-container">
      <view class="diagram-title">
        <text>人体肌肉分布</text>
        <text class="diagram-tip">了解肌肉结构 · 点击下方动作查看详情</text>
      </view>
      
      <!-- 视频播放器 -->
      <view class="video-container">
        <video 
          id="muscleVideo"
          class="muscle-video"
          src="https://jrchbzzwgqndaxsckvub.supabase.co/storage/v1/object/public/video/muscle.mp4"
          controls
          muted="{{isMuted}}"
          show-center-play-btn="{{true}}"
          show-play-btn="{{true}}"
          show-fullscreen-btn="{{true}}"
          enable-progress-gesture="{{true}}"
          object-fit="contain"
          direction="0"
          bindplay="onVideoPlay"
          bindpause="onVideoPause"
          bindended="onVideoEnded"
          binderror="onVideoError"
          bindwaiting="onVideoWaiting"
          bindloadedmetadata="onVideoLoaded"
          bindfullscreenchange="onFullscreenChange"
        ></video>
        
        <!-- 静音控制按钮 -->
        <view class="mute-btn" bindtap="toggleMute" wx:if="{{!isFullscreen}}">
          <image class="mute-icon" src="/images/icons/volume.svg" mode="aspectFit" wx:if="{{!isMuted}}"></image>
          <text class="mute-icon-text" wx:if="{{isMuted}}">🔇</text>
        </view>
        
        <!-- 全屏按钮（备用） -->
        <view class="fullscreen-btn" bindtap="requestFullscreen" wx:if="{{!isFullscreen}}">
          <text class="fullscreen-icon">⛶</text>
        </view>
        
        <!-- 视频加载失败提示 -->
        <view class="video-error-tip" wx:if="{{videoLoadError}}">
          <view class="error-icon">⚠️</view>
          <text class="error-title">视频暂时无法播放</text>
          <text class="error-desc">请稍后重试</text>
        </view>
        
        <view class="video-info" wx:if="{{!videoLoadError}}">
          <image class="info-icon" src="/images/icons/lightbulb.svg" mode="aspectFit"></image>
          <text class="info-text">人体肌肉分布视频</text>
          <text class="info-text">点击播放观看详细讲解</text>
        </view>
      </view>
    </view>

    <!-- 肌肉动作分类列表 -->
    <view class="muscle-groups">
      <!-- 胸部 -->
      <view class="muscle-group-section">
        <view class="group-header">
          <text class="group-icon">💪</text>
          <text class="group-title">胸部</text>
        </view>
        <view class="action-grid">
          <view class="action-card" 
                wx:for="{{chestActions}}" 
                wx:key="id"
                bindtap="goToActionDetail" 
                data-action="{{item}}">
            <text class="action-name">{{item.name}}</text>
            <text class="action-muscle">{{item.muscleGroup}}</text>
          </view>
        </view>
      </view>

      <!-- 背部 -->
      <view class="muscle-group-section">
        <view class="group-header">
          <text class="group-icon">🦾</text>
          <text class="group-title">背部</text>
        </view>
        <view class="action-grid">
          <view class="action-card" 
                wx:for="{{backActions}}" 
                wx:key="id"
                bindtap="goToActionDetail" 
                data-action="{{item}}">
            <text class="action-name">{{item.name}}</text>
            <text class="action-muscle">{{item.muscleGroup}}</text>
          </view>
        </view>
      </view>

      <!-- 肩部 -->
      <view class="muscle-group-section">
        <view class="group-header">
          <text class="group-icon">🏋️</text>
          <text class="group-title">肩部</text>
        </view>
        <view class="action-grid">
          <view class="action-card" 
                wx:for="{{shoulderActions}}" 
                wx:key="id"
                bindtap="goToActionDetail" 
                data-action="{{item}}">
            <text class="action-name">{{item.name}}</text>
            <text class="action-muscle">{{item.muscleGroup}}</text>
          </view>
        </view>
      </view>

      <!-- 手臂 -->
      <view class="muscle-group-section">
        <view class="group-header">
          <text class="group-icon">💪</text>
          <text class="group-title">手臂</text>
        </view>
        <view class="action-grid">
          <view class="action-card" 
                wx:for="{{armActions}}" 
                wx:key="id"
                bindtap="goToActionDetail" 
                data-action="{{item}}">
            <text class="action-name">{{item.name}}</text>
            <text class="action-muscle">{{item.muscleGroup}}</text>
          </view>
        </view>
      </view>

      <!-- 核心 -->
      <view class="muscle-group-section">
        <view class="group-header">
          <text class="group-icon">🔥</text>
          <text class="group-title">核心</text>
        </view>
        <view class="action-grid">
          <view class="action-card" 
                wx:for="{{coreActions}}" 
                wx:key="id"
                bindtap="goToActionDetail" 
                data-action="{{item}}">
            <text class="action-name">{{item.name}}</text>
            <text class="action-muscle">{{item.muscleGroup}}</text>
          </view>
        </view>
      </view>

      <!-- 臀部 -->
      <view class="muscle-group-section">
        <view class="group-header">
          <text class="group-icon">🍑</text>
          <text class="group-title">臀部</text>
        </view>
        <view class="action-grid">
          <view class="action-card" 
                wx:for="{{gluteActions}}" 
                wx:key="id"
                bindtap="goToActionDetail" 
                data-action="{{item}}">
            <text class="action-name">{{item.name}}</text>
            <text class="action-muscle">{{item.muscleGroup}}</text>
          </view>
        </view>
      </view>

      <!-- 大腿 -->
      <view class="muscle-group-section">
        <view class="group-header">
          <text class="group-icon">🦵</text>
          <text class="group-title">大腿</text>
        </view>
        <view class="action-grid">
          <view class="action-card" 
                wx:for="{{legActions}}" 
                wx:key="id"
                bindtap="goToActionDetail" 
                data-action="{{item}}">
            <text class="action-name">{{item.name}}</text>
            <text class="action-muscle">{{item.muscleGroup}}</text>
          </view>
        </view>
      </view>

      <!-- 小腿 -->
      <view class="muscle-group-section">
        <view class="group-header">
          <text class="group-icon">🦿</text>
          <text class="group-title">小腿</text>
        </view>
        <view class="action-grid">
          <view class="action-card" 
                wx:for="{{calfActions}}" 
                wx:key="id"
                bindtap="goToActionDetail" 
                data-action="{{item}}">
            <text class="action-name">{{item.name}}</text>
            <text class="action-muscle">{{item.muscleGroup}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 肌肉详情弹窗 -->
  <view class="muscle-detail-modal" wx:if="{{showMuscleDetail}}">
    <view class="modal-mask" bindtap="hideMuscleDetail"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">{{muscleDetails[selectedMuscle].name}}</text>
        <button class="close-btn" bindtap="hideMuscleDetail">×</button>
      </view>
      
      <view class="modal-body">
        <view class="detail-row">
          <text class="detail-label">功能:</text>
          <text class="detail-value">{{muscleDetails[selectedMuscle].function}}</text>
        </view>
        
        <view class="detail-row">
          <text class="detail-label">起点:</text>
          <text class="detail-value">{{muscleDetails[selectedMuscle].origin}}</text>
        </view>
        
        <view class="detail-row">
          <text class="detail-label">止点:</text>
          <text class="detail-value">{{muscleDetails[selectedMuscle].insertion}}</text>
        </view>
        
        <view class="detail-row">
          <text class="detail-label">神经支配:</text>
          <text class="detail-value">{{muscleDetails[selectedMuscle].innervation}}</text>
        </view>
        
        <view class="detail-row">
          <text class="detail-label">血液供应:</text>
          <text class="detail-value">{{muscleDetails[selectedMuscle].bloodSupply}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 肌肉张力计算页面 -->
  <view class="tab-content" wx:if="{{currentTab === 1}}">
    <!-- 肌肉张力知识点 -->
    <view class="knowledge-section">
      <view class="knowledge-header">
        <image class="knowledge-icon" src="/images/icons/book.svg" mode="aspectFit"></image>
        <text class="knowledge-title">肌肉张力基础知识</text>
      </view>
      
      <view class="knowledge-content">
        <!-- 什么是肌肉张力 -->
        <view class="knowledge-card">
          <view class="card-header">
            <text class="card-icon">💪</text>
            <text class="card-title">什么是肌肉张力？</text>
          </view>
          <view class="card-body">
            <text class="card-text">肌肉张力（Muscle Tension）是指肌肉在静止或收缩状态下产生的内部张力。它由主动收缩力和被动弹性力组成，是评估肌肉功能和训练效果的重要指标。</text>
            <view class="card-highlight">
              <text class="highlight-label">组成部分：</text>
              <text class="highlight-text">• 主动张力：肌肉主动收缩产生</text>
              <text class="highlight-text">• 被动张力：肌肉被拉伸时的弹性反应</text>
            </view>
          </view>
        </view>

        <!-- 力矩与杠杆原理 -->
        <view class="knowledge-card">
          <view class="card-header">
            <text class="card-icon">⚖️</text>
            <text class="card-title">力矩与杠杆原理</text>
          </view>
          <view class="card-body">
            <text class="card-text">人体关节系统是一个复杂的杠杆系统。力矩（Torque）是力与力臂的乘积，决定了肌肉需要产生多大的张力来克服外部负荷。</text>
            <view class="card-formula">
              <text class="formula-label">核心公式：</text>
              <text class="formula-text">力矩 (M) = 力 (F) × 力臂 (d)</text>
              <text class="formula-note">力臂是从关节到力作用线的垂直距离</text>
            </view>
            <view class="card-highlight">
              <text class="highlight-text">• 力臂越长，产生的力矩越大</text>
              <text class="highlight-text">• 肌肉需要更大的张力来平衡外部力矩</text>
            </view>
          </view>
        </view>

        <!-- 影响因素 -->
        <view class="knowledge-card">
          <view class="card-header">
            <text class="card-icon">🔬</text>
            <text class="card-title">影响肌肉张力的因素</text>
          </view>
          <view class="card-body">
            <view class="factor-grid">
              <view class="factor-item">
                <image class="factor-icon" src="/images/icons/muscle.svg" mode="aspectFit"></image>
                <view class="factor-content">
                  <text class="factor-title">肌纤维类型</text>
                  <text class="factor-desc">快肌纤维（Type II）产生更大张力，适合爆发力训练</text>
                </view>
              </view>
              <view class="factor-item">
                <image class="factor-icon" src="/images/icons/ruler.svg" mode="aspectFit"></image>
                <view class="factor-content">
                  <text class="factor-title">肌肉长度</text>
                  <text class="factor-desc">最佳长度时张力最大，过长或过短都会降低张力</text>
                </view>
              </view>
              <view class="factor-item">
                <image class="factor-icon" src="/images/icons/lightning.svg" mode="aspectFit"></image>
                <view class="factor-content">
                  <text class="factor-title">收缩速度</text>
                  <text class="factor-desc">速度越快张力越小，慢速训练能产生更大张力</text>
                </view>
              </view>
              <view class="factor-item">
                <image class="factor-icon" src="/images/icons/repeat.svg" mode="aspectFit"></image>
                <view class="factor-content">
                  <text class="factor-title">杠杆效应</text>
                  <text class="factor-desc">力臂长度影响实际张力，不同动作杠杆效率不同</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 收缩类型 -->
        <view class="knowledge-card">
          <view class="card-header">
            <text class="card-icon">🏋️</text>
            <text class="card-title">肌肉收缩类型</text>
          </view>
          <view class="card-body">
            <view class="contraction-types">
              <view class="contraction-item">
                <text class="contraction-name">等张收缩（Isotonic）</text>
                <text class="contraction-desc">肌肉长度改变，张力保持相对恒定</text>
                <view class="contraction-subtypes">
                  <text class="subtype">• 向心收缩：肌肉缩短（举起重量）</text>
                  <text class="subtype">• 离心收缩：肌肉拉长（放下重量）</text>
                </view>
              </view>
              <view class="contraction-item">
                <text class="contraction-name">等长收缩（Isometric）</text>
                <text class="contraction-desc">肌肉长度不变，产生静态张力</text>
                <text class="contraction-example">例如：平板支撑、靠墙静蹲</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 训练意义 -->
        <view class="knowledge-card">
          <view class="card-header">
            <text class="card-icon">🎯</text>
            <text class="card-title">了解肌肉张力的训练意义</text>
          </view>
          <view class="card-body">
            <view class="benefit-list">
              <view class="benefit-item">
                <text class="benefit-number">1</text>
                <view class="benefit-content">
                  <text class="benefit-title">选择合适训练重量</text>
                  <text class="benefit-desc">根据目标肌肉的张力承受能力，选择最优负荷</text>
                </view>
              </view>
              <view class="benefit-item">
                <text class="benefit-number">2</text>
                <view class="benefit-content">
                  <text class="benefit-title">避免肌肉过度疲劳</text>
                  <text class="benefit-desc">了解张力极限，防止过度训练导致损伤</text>
                </view>
              </view>
              <view class="benefit-item">
                <text class="benefit-number">3</text>
                <view class="benefit-content">
                  <text class="benefit-title">优化训练效果</text>
                  <text class="benefit-desc">在最佳张力范围内训练，促进肌肉生长</text>
                </view>
              </view>
              <view class="benefit-item">
                <text class="benefit-number">4</text>
                <view class="benefit-content">
                  <text class="benefit-title">预防运动损伤</text>
                  <text class="benefit-desc">避免超出肌肉张力承受范围的动作</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 计算原理 -->
        <view class="knowledge-card">
          <view class="card-header">
            <text class="card-icon">🧮</text>
            <text class="card-title">肌肉张力计算原理</text>
          </view>
          <view class="card-body">
            <text class="card-text">基于力矩平衡原理，当关节处于平衡状态时：</text>
            <view class="card-formula">
              <text class="formula-text">肌肉张力 × 肌肉力臂 = 负重 × 负重力臂</text>
            </view>
            <text class="card-text">通过测量负重和力臂距离，可以估算肌肉承受的张力。不同动作的杠杆效率不同，因此需要使用特定的系数进行修正。</text>
            <view class="card-highlight">
              <text class="highlight-label">注意事项：</text>
              <text class="highlight-text">• 计算结果为估算值，实际张力受多种因素影响</text>
              <text class="highlight-text">• 不同个体的肌肉力臂长度存在差异</text>
              <text class="highlight-text">• 动作技术和姿势会影响实际张力分布</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 按肌群分类的训练动作选择 -->
    <view class="exercise-selection">
      <view class="selection-header">
        <image class="selection-icon" src="/images/icons/dumbbell.svg" mode="aspectFit"></image>
        <text class="selection-title">选择训练动作</text>
      </view>

      <!-- 上肢训练 -->
      <view class="muscle-category">
        <view class="category-header">
          <text class="category-icon">💪</text>
          <text class="category-title">上肢训练</text>
        </view>
        <view class="exercise-grid">
          <view class="exercise-card" 
                wx:for="{{upperBodyExercises}}" 
                wx:key="index"
                bindtap="goToTensionCalculator" 
                data-exercise="{{item}}">
            <text class="exercise-icon">{{item.icon}}</text>
            <text class="exercise-name">{{item.exercise}}</text>
            <text class="exercise-muscle">{{item.muscle}}</text>
          </view>
        </view>
      </view>

      <!-- 下肢训练 -->
      <view class="muscle-category">
        <view class="category-header">
          <text class="category-icon">🦵</text>
          <text class="category-title">下肢训练</text>
        </view>
        <view class="exercise-grid">
          <view class="exercise-card" 
                wx:for="{{lowerBodyExercises}}" 
                wx:key="index"
                bindtap="goToTensionCalculator" 
                data-exercise="{{item}}">
            <text class="exercise-icon">{{item.icon}}</text>
            <text class="exercise-name">{{item.exercise}}</text>
            <text class="exercise-muscle">{{item.muscle}}</text>
          </view>
        </view>
      </view>

      <!-- 躯干训练 -->
      <view class="muscle-category">
        <view class="category-header">
          <text class="category-icon">🏋️</text>
          <text class="category-title">躯干训练</text>
        </view>
        <view class="exercise-grid">
          <view class="exercise-card" 
                wx:for="{{torsoExercises}}" 
                wx:key="index"
                bindtap="goToTensionCalculator" 
                data-exercise="{{item}}">
            <text class="exercise-icon">{{item.icon}}</text>
            <text class="exercise-name">{{item.exercise}}</text>
            <text class="exercise-muscle">{{item.muscle}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>