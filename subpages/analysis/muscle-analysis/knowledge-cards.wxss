/* 知识卡片样式 */
.knowledge-section {
  margin-bottom: 30rpx;
}

.knowledge-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.3);
}

.knowledge-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
  filter: brightness(0) invert(1);
}

.knowledge-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.knowledge-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 知识卡片 */
.knowledge-card {
  background: linear-gradient(135deg, #ffffff 0%, #fafbfc 100%);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid rgba(16, 185, 129, 0.1);
}

.card-header {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-bottom: 2rpx solid rgba(16, 185, 129, 0.1);
}

.card-icon {
  font-size: 44rpx;
  margin-right: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.card-body {
  padding: 30rpx;
}

.card-text {
  font-size: 28rpx;
  line-height: 48rpx;
  color: #333333;
  text-align: justify;
  margin-bottom: 20rpx;
}

/* 高亮区域 */
.card-highlight {
  background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 16rpx;
  border-left: 6rpx solid #fb923c;
}

.highlight-label {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #ea580c;
  margin-bottom: 12rpx;
}

.highlight-text {
  display: block;
  font-size: 26rpx;
  line-height: 40rpx;
  color: #9a3412;
  margin-bottom: 8rpx;
}

.highlight-text:last-child {
  margin-bottom: 0;
}

/* 公式区域 */
.card-formula {
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx 0;
  border: 2rpx solid #10b981;
}

.formula-label {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #059669;
  margin-bottom: 12rpx;
}

.formula-text {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #047857;
  text-align: center;
  margin: 16rpx 0;
  font-family: 'Courier New', monospace;
}

.formula-note {
  display: block;
  font-size: 24rpx;
  color: #059669;
  text-align: center;
  margin-top: 12rpx;
}

/* 因素网格 */
.factor-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 16rpx;
}

.factor-item {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  border: 2rpx solid rgba(16, 185, 129, 0.1);
}

.factor-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 12rpx;
  filter: brightness(0) saturate(100%) invert(58%) sepia(89%) saturate(449%) hue-rotate(101deg) brightness(95%) contrast(92%);
}

.factor-content {
  flex: 1;
}

.factor-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.factor-desc {
  display: block;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #666666;
}

/* 收缩类型 */
.contraction-types {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.contraction-item {
  background: linear-gradient(135deg, #fef3f2 0%, #fee2e2 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  border-left: 6rpx solid #ef4444;
}

.contraction-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #dc2626;
  margin-bottom: 12rpx;
}

.contraction-desc {
  display: block;
  font-size: 26rpx;
  line-height: 40rpx;
  color: #991b1b;
  margin-bottom: 12rpx;
}

.contraction-subtypes {
  margin-top: 12rpx;
}

.subtype {
  display: block;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #7f1d1d;
  margin-bottom: 6rpx;
}

.contraction-example {
  display: block;
  font-size: 24rpx;
  color: #991b1b;
  font-style: italic;
  margin-top: 8rpx;
}

/* 训练意义列表 */
.benefit-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 16rpx;
}

.benefit-item {
  display: flex;
  align-items: flex-start;
  background: linear-gradient(135deg, #fef3f2 0%, #fff7ed 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(251, 146, 60, 0.2);
}

.benefit-number {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #fb923c 0%, #f97316 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.benefit-content {
  flex: 1;
}

.benefit-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.benefit-desc {
  display: block;
  font-size: 26rpx;
  line-height: 40rpx;
  color: #666666;
}

/* 训练动作选择 */
.exercise-selection {
  margin-top: 30rpx;
}

.selection-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #fb923c 0%, #f97316 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(251, 146, 60, 0.3);
}

.selection-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
  filter: brightness(0) invert(1);
}

.selection-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 1rpx;
}

/* 肌群分类 */
.muscle-category {
  margin-bottom: 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fafbfc 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid rgba(16, 185, 129, 0.1);
}

.category-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.category-icon {
  font-size: 44rpx;
  margin-right: 16rpx;
}

.category-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.exercise-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.exercise-card {
  background: linear-gradient(135deg, #f0f9ff 0%, #fef3f2 100%);
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 160rpx;
  box-shadow: 0 2rpx 12rpx rgba(16, 185, 129, 0.1);
  border: 2rpx solid rgba(16, 185, 129, 0.1);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.exercise-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(16, 185, 129, 0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.exercise-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(16, 185, 129, 0.15);
}

.exercise-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.exercise-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.exercise-muscle {
  font-size: 24rpx;
  color: #10b981;
  text-align: center;
  position: relative;
  z-index: 1;
}
