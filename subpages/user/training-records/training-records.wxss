/* 训练记录页面样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #07c160, #06a552);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(7, 193, 96, 0.3);
  color: white;
  position: relative;
  overflow: hidden;
  animation: statsSlideIn 0.6s ease;
}

@keyframes statsSlideIn {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.stats-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation: rotate 20s linear infinite;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.stats-title {
  font-size: 36rpx;
  font-weight: bold;
}

.stats-date {
  font-size: 28rpx;
  opacity: 0.9;
}

.stats-content {
  display: flex;
  justify-content: space-between;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 筛选区域 */
.filter-section {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.filter-item {
  margin-bottom: 30rpx;
}

.filter-item:last-child {
  margin-bottom: 0;
}

.filter-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.filter-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
}

.filter-arrow {
  font-size: 24rpx;
  color: #999;
}

.type-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.type-item {
  padding: 15rpx 30rpx;
  background: #f8f8f8;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s ease;
}

.type-item.active {
  background: #07c160;
  color: white;
}

/* 自定义训练计划切换 */
.custom-plans-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.toggle-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.toggle-right {
  display: flex;
  align-items: center;
}

.toggle-count {
  font-size: 26rpx;
  color: #07c160;
  margin-right: 15rpx;
  font-weight: 500;
}

.toggle-icon {
  font-size: 28rpx;
  color: #666;
}

/* 自定义训练计划列表 */
.custom-plans-section {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-count {
  font-size: 26rpx;
  color: #666;
}

.add-plan-btn {
  background: #07c160;
  color: white;
  border-radius: 40rpx;
  padding: 10rpx 30rpx;
  font-size: 26rpx;
  line-height: 1.6;
  border: none;
}

.custom-plans-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.custom-plan-card {
  background: #f8f8f8;
  border-radius: 20rpx;
  padding: 30rpx;
  transition: all 0.3s ease;
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.plan-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.plan-category {
  background: #07c160;
  color: white;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.plan-exercises {
  margin-bottom: 20rpx;
}

.exercise-item {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.exercise-item:last-child {
  border-bottom: none;
}

.exercise-checkbox {
  margin-right: 20rpx;
}

.exercise-content {
  flex: 1;
}

.exercise-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.exercise-details {
  font-size: 24rpx;
  color: #666;
}

.plan-actions {
  display: flex;
  justify-content: flex-end;
}

/* 记录列表 */
.records-section {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.export-btn {
  background: #07c160;
  color: white;
  border-radius: 40rpx;
  padding: 10rpx 30rpx;
  font-size: 26rpx;
  line-height: 1.6;
  border: none;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 记录卡片 */
.record-card {
  background: #f8f8f8;
  border-radius: 20rpx;
  padding: 30rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  animation: recordFadeIn 0.5s ease;
}

@keyframes recordFadeIn {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.record-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(180deg, #07c160, #06a552);
  transform: scaleY(0);
  transition: transform 0.3s ease;
}

.record-card:active::before {
  transform: scaleY(1);
}

.record-card:active {
  transform: translateX(8rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.record-type {
  display: flex;
  align-items: center;
}

.type-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.type-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.record-content {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.record-detail {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.record-actions {
  display: flex;
  justify-content: flex-end;
}

.delete-btn {
  background: #ff4757;
  color: white;
  border-radius: 40rpx;
  padding: 8rpx 25rpx;
  font-size: 24rpx;
  line-height: 1.6;
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #bbb;
}