<!--index.wxml-->
<view class="page">
  <!-- 顶部装饰 -->
  <view class="bg-decoration">
    <view class="gradient-orb orb-1"></view>
    <view class="gradient-orb orb-2"></view>
    <view class="gradient-orb orb-3"></view>
  </view>

  <!-- 欢迎区域 -->
  <view class="welcome-section">
    <view class="user-info">
      <view class="user-text">
        <text class="greeting">{{greeting}}</text>
        <text class="username">{{userInfo.name || '健身达人'}}</text>
      </view>
      <image src="{{userInfo.avatar || '/images/placeholder.png'}}" class="avatar" mode="aspectFill"></image>
    </view>
  </view>

  <!-- 今日目标卡片 -->
  <view class="goal-section">
    <view class="goal-card">
      <view class="goal-header">
        <view class="goal-title-box">
          <image src="/images/icons/target.svg" class="goal-icon" mode="aspectFit"></image>
          <text class="goal-title">今日目标</text>
        </view>
        <view class="goal-percentage">
          <text class="percentage-num">{{todayProgress}}</text>
          <text class="percentage-symbol">%</text>
        </view>
      </view>

      <view class="goal-stats-row">
        <view class="stat-item">
          <view class="stat-icon-box">
            <image src="/images/icons/clock.svg" class="stat-icon" mode="aspectFit"></image>
          </view>
          <view class="stat-content">
            <text class="stat-value">{{todayMinutes}}/{{dailyGoal.minutes}}</text>
            <text class="stat-label">分钟</text>
          </view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-icon-box">
            <image src="/images/icons/fire.svg" class="stat-icon" mode="aspectFit"></image>
          </view>
          <view class="stat-content">
            <text class="stat-value">{{todayCalories}}/{{dailyGoal.calories}}</text>
            <text class="stat-label">千卡</text>
          </view>
        </view>
      </view>

      <view class="progress-wrapper">
        <view class="progress-track">
          <view class="progress-bar" style="width: {{todayProgress}}%">
            <view class="progress-glow"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 快速开始 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">快速开始</text>
    </view>

    <view class="action-grid">
      <view class="action-btn primary" bindtap="goToTraining" hover-class="action-hover">
        <view class="action-icon-box primary-bg">
          <image src="/images/icons/dumbbell.svg" class="action-icon" mode="aspectFit"></image>
        </view>
        <text class="action-text">开始训练</text>
      </view>

      <view class="action-btn secondary" bindtap="goToFoodRecognition" hover-class="action-hover">
        <view class="action-icon-box secondary-bg">
          <image src="/images/icons/apple.svg" class="action-icon" mode="aspectFit"></image>
        </view>
        <text class="action-text">食物识别</text>
      </view>

      <view class="action-btn" bindtap="goToCustomPlans" hover-class="action-hover">
        <view class="action-icon-box">
          <image src="/images/icons/clipboard.svg" class="action-icon" mode="aspectFit"></image>
        </view>
        <text class="action-text">我的计划</text>
      </view>

      <view class="action-btn" bindtap="goToMuscleAnalysis" hover-class="action-hover">
        <view class="action-icon-box">
          <image src="/images/icons/microscope.svg" class="action-icon" mode="aspectFit"></image>
        </view>
        <text class="action-text">肌肉分析</text>
      </view>
    </view>
  </view>

  <!-- 推荐训练 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">推荐训练</text>
      <view class="more-btn" bindtap="goToTraining">
        <text class="more-text">查看全部</text>
        <text class="more-arrow">›</text>
      </view>
    </view>

    <scroll-view class="plans-scroll" scroll-x="true" show-scrollbar="false">
      <view class="plans-list">
        <view class="plan-card" wx:for="{{recommendedPlans}}" wx:key="id" bindtap="goToPlanDetail" data-id="{{item.id}}" hover-class="plan-hover">
          <view class="plan-image-box">
            <image src="{{item.coverImage}}" class="plan-image" mode="aspectFill"></image>
            <view class="plan-badge {{item.difficultyLevel}}">{{item.difficulty}}</view>
            <view class="plan-duration">
              <image src="/images/icons/timer.svg" class="duration-icon" mode="aspectFit"></image>
              <text class="duration-text">{{item.duration}}</text>
            </view>
          </view>
          <view class="plan-info">
            <text class="plan-title">{{item.title}}</text>
            <text class="plan-category">{{item.category}}</text>
            <view class="plan-footer">
              <view class="plan-calories">
                <image src="/images/icons/flame.svg" class="cal-icon" mode="aspectFit"></image>
                <text class="cal-text">{{item.calories}} 千卡</text>
              </view>
              <view class="plan-rating">
                <image src="/images/icons/star.svg" class="star-icon" mode="aspectFit"></image>
                <text class="rating-num">{{item.rating}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 本周数据 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">本周数据</text>
    </view>

    <view class="stats-grid">
      <view class="stat-card" hover-class="stat-hover">
        <image src="/images/icons/calendar.svg" class="stat-icon-img" mode="aspectFit"></image>
        <text class="stat-number">{{weekStats.totalDays}}</text>
        <text class="stat-name">训练天数</text>
      </view>
      <view class="stat-card" hover-class="stat-hover">
        <image src="/images/icons/timer.svg" class="stat-icon-img" mode="aspectFit"></image>
        <text class="stat-number">{{weekStats.totalMinutes}}</text>
        <text class="stat-name">总时长(分)</text>
      </view>
      <view class="stat-card" hover-class="stat-hover">
        <image src="/images/icons/flame.svg" class="stat-icon-img" mode="aspectFit"></image>
        <text class="stat-number">{{weekStats.totalCalories}}</text>
        <text class="stat-name">消耗卡路里</text>
      </view>
      <view class="stat-card streak" hover-class="stat-hover">
        <image src="/images/icons/lightning.svg" class="stat-icon-img" mode="aspectFit"></image>
        <text class="stat-number">{{weekStats.continuousDays}}</text>
        <text class="stat-name">连续天数</text>
      </view>
    </view>
  </view>

  <view class="bottom-safe"></view>
</view>
