<!--index.wxml-->
<view class="page">
  <!-- 顶部装饰 -->
  <view class="bg-decoration">
    <view class="gradient-orb orb-1"></view>
    <view class="gradient-orb orb-2"></view>
    <view class="gradient-orb orb-3"></view>
  </view>

  <!-- 欢迎区域 -->
  <view class="welcome-section">
    <view class="welcome-card">
      <view class="user-info">
        <view class="user-text">
          <text class="greeting">{{greeting}}</text>
          <text class="username">{{userInfo.name || '健身达人'}}</text>
          <view class="greeting-decoration"></view>
        </view>
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <view class="avatar-wrapper">
            <image src="{{userInfo.avatar || '/images/ui/placeholder.png'}}" class="avatar" mode="aspectFill"></image>
            <view class="avatar-ring"></view>
            <view class="avatar-edit-hint">
              <image src="/images/icons/edit.svg" class="edit-icon" mode="aspectFit"></image>
            </view>
          </view>
        </button>
      </view>
    </view>
  </view>

  <!-- 今日目标卡片 -->
  <view class="goal-section">
    <view class="goal-card">
      <view class="goal-header">
        <view class="goal-title-box">
          <view class="goal-icon-wrapper">
            <image src="/images/icons/target.svg" class="goal-icon" mode="aspectFit"></image>
          </view>
          <view class="goal-title-group">
            <text class="goal-title">今日目标</text>
            <text class="goal-subtitle">坚持就是胜利</text>
          </view>
        </view>
        <view class="goal-percentage">
          <text class="percentage-num">{{todayProgress}}</text>
          <text class="percentage-symbol">%</text>
        </view>
      </view>

      <view class="goal-stats-row">
        <view class="stat-item">
          <view class="stat-icon-box">
            <image src="/images/icons/clock.svg" class="stat-icon" mode="aspectFit"></image>
          </view>
          <view class="stat-content">
            <text class="stat-value">{{todayMinutes}}<text class="stat-unit">/{{dailyGoal.minutes}}</text></text>
            <text class="stat-label">分钟</text>
          </view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-icon-box">
            <image src="/images/icons/fire.svg" class="stat-icon" mode="aspectFit"></image>
          </view>
          <view class="stat-content">
            <text class="stat-value">{{todayCalories}}<text class="stat-unit">/{{dailyGoal.calories}}</text></text>
            <text class="stat-label">千卡</text>
          </view>
        </view>
      </view>

      <view class="progress-wrapper">
        <view class="progress-track">
          <view class="progress-bar" style="width: {{todayProgress}}%"></view>
        </view>
        <view class="progress-labels">
          <text class="progress-label-start">0%</text>
          <text class="progress-label-end">100%</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快速开始 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">快速开始</text>
    </view>

    <view class="action-grid">
      <view class="action-btn primary" bindtap="goToTraining" hover-class="action-hover">
        <view class="action-icon-box primary-bg">
          <image src="/images/icons/dumbbell.svg" class="action-icon" mode="aspectFit"></image>
        </view>
        <text class="action-text">开始训练</text>
      </view>

      <view class="action-btn secondary" bindtap="goToFoodRecognition" hover-class="action-hover">
        <view class="action-icon-box secondary-bg">
          <image src="/images/icons/apple.svg" class="action-icon" mode="aspectFit"></image>
        </view>
        <text class="action-text">食物识别</text>
      </view>

      <view class="action-btn" bindtap="goToCustomPlans" hover-class="action-hover">
        <view class="action-icon-box">
          <image src="/images/icons/clipboard.svg" class="action-icon" mode="aspectFit"></image>
        </view>
        <text class="action-text">我的计划</text>
      </view>

      <view class="action-btn" bindtap="goToMuscleAnalysis" hover-class="action-hover">
        <view class="action-icon-box">
          <image src="/images/icons/microscope.svg" class="action-icon" mode="aspectFit"></image>
        </view>
        <text class="action-text">肌肉分析</text>
      </view>
    </view>
  </view>

  <!-- 推荐训练 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title-wrapper">
        <text class="section-title">推荐训练</text>
        <view class="title-underline"></view>
      </view>
      <view class="more-btn" bindtap="goToTraining">
        <text class="more-text">查看全部</text>
        <text class="more-arrow">→</text>
      </view>
    </view>

    <scroll-view class="plans-scroll" scroll-x="true" show-scrollbar="false">
      <view class="plans-list">
        <view class="plan-card" wx:for="{{recommendedPlans}}" wx:key="id" bindtap="goToPlanDetail" data-id="{{item.id}}" hover-class="plan-hover">
          <view class="plan-image-box">
            <image src="{{item.coverImage}}" class="plan-image" mode="aspectFit"></image>
            <view class="plan-overlay"></view>
            <view class="plan-badge {{item.difficultyLevel}}">
              <view class="badge-dot"></view>
              <text>{{item.difficulty}}</text>
            </view>
          </view>
          <view class="plan-info">
            <text class="plan-title">{{item.title}}</text>
            <text class="plan-category">{{item.category}}</text>
            <view class="plan-meta">
              <view class="meta-item">
                <image src="/images/icons/timer.svg" class="meta-icon" mode="aspectFit"></image>
                <text class="meta-text">{{item.duration}}</text>
              </view>
              <view class="meta-divider"></view>
              <view class="meta-item">
                <image src="/images/icons/flame.svg" class="meta-icon" mode="aspectFit"></image>
                <text class="meta-text">{{item.calories}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 本周数据 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">本周数据</text>
    </view>

    <view class="stats-grid">
      <view class="stat-card" hover-class="stat-hover">
        <image src="/images/icons/calendar.svg" class="stat-icon-img" mode="aspectFit"></image>
        <text class="stat-number">{{weekStats.totalDays}}</text>
        <text class="stat-name">训练天数</text>
      </view>
      <view class="stat-card" hover-class="stat-hover">
        <image src="/images/icons/timer.svg" class="stat-icon-img" mode="aspectFit"></image>
        <text class="stat-number">{{weekStats.totalMinutes}}</text>
        <text class="stat-name">总时长(分)</text>
      </view>
      <view class="stat-card" hover-class="stat-hover">
        <image src="/images/icons/flame.svg" class="stat-icon-img" mode="aspectFit"></image>
        <text class="stat-number">{{weekStats.totalCalories}}</text>
        <text class="stat-name">消耗卡路里</text>
      </view>
      <view class="stat-card streak" hover-class="stat-hover">
        <image src="/images/icons/lightning.svg" class="stat-icon-img" mode="aspectFit"></image>
        <text class="stat-number">{{weekStats.continuousDays}}</text>
        <text class="stat-name">连续天数</text>
      </view>
    </view>
  </view>

  <!-- 社交模块 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">好友动态</text>
      <view class="more-btn" bindtap="goToDynamics">
        <text class="more-text">查看全部</text>
        <text class="more-arrow">→</text>
      </view>
    </view>

    <!-- 社交快捷入口 -->
    <view class="social-shortcuts">
      <view class="shortcut-item" bindtap="goToFriends" hover-class="shortcut-hover">
        <view class="shortcut-icon-box friends-bg">
          <image src="/images/icons/users.svg" class="shortcut-icon" mode="aspectFit"></image>
          <view wx:if="{{friendsCount > 0}}" class="shortcut-badge">{{friendsCount}}</view>
        </view>
        <text class="shortcut-text">我的好友</text>
      </view>

      <view class="shortcut-item" bindtap="goToRanking" hover-class="shortcut-hover">
        <view class="shortcut-icon-box ranking-bg">
          <image src="/images/icons/bar-chart.svg" class="shortcut-icon" mode="aspectFit"></image>
          <view wx:if="{{myRanking.weekRank > 0}}" class="shortcut-badge rank">{{myRanking.weekRank}}</view>
        </view>
        <text class="shortcut-text">排行榜</text>
      </view>

      <view class="shortcut-item" bindtap="goToDynamics" hover-class="shortcut-hover">
        <view class="shortcut-icon-box dynamics-bg">
          <image src="/images/icons/bell.svg" class="shortcut-icon" mode="aspectFit"></image>
        </view>
        <text class="shortcut-text">动态广场</text>
      </view>
    </view>

    <!-- 最近动态 -->
    <view wx:if="{{recentDynamics.length > 0}}" class="dynamics-preview">
      <view 
        wx:for="{{recentDynamics}}" 
        wx:key="id" 
        class="dynamic-item"
        hover-class="dynamic-hover"
      >
        <image class="dynamic-avatar" src="{{item.userAvatar}}" mode="aspectFit"></image>
        <view class="dynamic-content">
          <view class="dynamic-header">
            <text class="dynamic-username">{{item.userName}}</text>
            <text class="dynamic-time">{{item.timeText}}</text>
          </view>
          <text class="dynamic-text">{{item.content}}</text>
          <view wx:if="{{item.type === 'training'}}" class="dynamic-stats">
            <text class="dynamic-stat">⏱️ {{item.duration}}分钟</text>
            <text class="dynamic-stat">🔥 {{item.calories}}千卡</text>
          </view>
        </view>
        <view class="dynamic-like" bindtap="toggleLike" data-id="{{item.id}}" catchtap="toggleLike">
          <image 
            class="like-icon {{item.isLiked ? 'liked' : ''}}" 
            src="{{item.isLiked ? '/images/icons/star.svg' : '/images/icons/star.svg'}}" 
            mode="aspectFit"
          ></image>
          <text class="like-count {{item.isLiked ? 'liked' : ''}}">{{item.likes}}</text>
        </view>
      </view>
    </view>

    <view wx:else class="empty-dynamics">
      <image class="empty-icon" src="/images/icons/empty.svg" mode="aspectFit"></image>
      <text class="empty-text">还没有好友动态</text>
      <text class="empty-hint" bindtap="goToFriends">添加好友，查看他们的训练动态</text>
    </view>
  </view>

  <view class="bottom-safe"></view>
</view>
