/* 清新活力风格 - Fresh Energy */

page {
  background: linear-gradient(180deg, #f0f9ff 0%, #fef3f2 100%);
  min-height: 100vh;
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 0 24rpx 40rpx;
}

/* 背景装饰 */
.bg-decoration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.gradient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.4;
  animation: float 20s ease-in-out infinite;
}

.orb-1 {
  width: 500rpx;
  height: 500rpx;
  background: linear-gradient(135deg, #a7f3d0, #6ee7b7);
  top: -150rpx;
  right: -100rpx;
}

.orb-2 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #fbbf24, #fb923c);
  bottom: 20%;
  left: -100rpx;
  animation-delay: -5s;
}

.orb-3 {
  width: 350rpx;
  height: 350rpx;
  background: linear-gradient(135deg, #93c5fd, #60a5fa);
  top: 40%;
  right: -80rpx;
  animation-delay: -10s;
}

@keyframes float {
  0%, 100% {
    transform: translate(0, 0) scale(1);
  }
  33% {
    transform: translate(30rpx, -30rpx) scale(1.1);
  }
  66% {
    transform: translate(-20rpx, 20rpx) scale(0.9);
  }
}

/* 欢迎区域 */
.welcome-section {
  position: relative;
  z-index: 1;
  padding-top: 40rpx;
  margin-bottom: 32rpx;
}

.user-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-text {
  flex: 1;
}

.greeting {
  display: block;
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 8rpx;
  font-weight: 500;
  position: relative;
  padding-left: 32rpx;
}

.greeting::before {
  content: '👋';
  position: absolute;
  left: 0;
  font-size: 24rpx;
}

.username {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: -0.5rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  border: 4rpx solid #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

/* 今日目标卡片 */
.goal-section {
  position: relative;
  z-index: 1;
  margin-bottom: 40rpx;
}

.goal-card {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 32rpx;
  padding: 36rpx;
  box-shadow: 0 12rpx 40rpx rgba(16, 185, 129, 0.3);
  position: relative;
  overflow: hidden;
}

.goal-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.goal-card::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 150rpx;
  height: 150rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.goal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.goal-title-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.goal-icon {
  width: 32rpx;
  height: 32rpx;
}

.goal-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.goal-percentage {
  display: flex;
  align-items: baseline;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  backdrop-filter: blur(10rpx);
}

.percentage-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.percentage-symbol {
  font-size: 24rpx;
  color: #ffffff;
  margin-left: 4rpx;
}

.goal-stats-row {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.stat-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stat-icon-box {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  backdrop-filter: blur(10rpx);
}

.stat-icon {
  width: 28rpx;
  height: 28rpx;
}

.stat-content {
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 4rpx;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.3);
}

.progress-wrapper {
  margin-top: 8rpx;
  position: relative;
  z-index: 1;
}

.progress-track {
  height: 14rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 7rpx;
  overflow: hidden;
  position: relative;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.progress-bar {
  height: 100%;
  background: #ffffff;
  border-radius: 7rpx;
  position: relative;
  transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 0 20rpx rgba(255, 255, 255, 0.8);
}

.progress-bar::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 20rpx;
  height: 20rpx;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 0 0 12rpx rgba(255, 255, 255, 0.9);
}

.progress-glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4));
  animation: shimmer 2s infinite;
}

@keyframes shimmer {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}

/* 通用区块 */
.section {
  position: relative;
  z-index: 1;
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.more-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.more-text {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

.more-arrow {
  font-size: 32rpx;
  color: #10b981;
  font-weight: 700;
}

/* 快速开始按钮 */
.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.action-btn {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(16, 185, 129, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.action-btn:active::before {
  opacity: 1;
}

.action-btn.primary {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.action-btn.secondary {
  background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.3);
}

.action-hover {
  transform: translateY(-6rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
}

.action-btn.primary.action-hover {
  box-shadow: 0 12rpx 32rpx rgba(16, 185, 129, 0.4);
}

.action-btn.secondary.action-hover {
  box-shadow: 0 12rpx 32rpx rgba(245, 158, 11, 0.4);
}

.action-icon-box {
  width: 80rpx;
  height: 80rpx;
  background: #f1f5f9;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s ease;
}

.action-btn:active .action-icon-box {
  transform: scale(0.9);
}

.action-icon-box.primary-bg {
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
}

.action-icon-box.secondary-bg {
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
}

.action-icon {
  width: 40rpx;
  height: 40rpx;
}

.action-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #334155;
  letter-spacing: 0.5rpx;
}

.action-btn.primary .action-text,
.action-btn.secondary .action-text {
  color: #ffffff;
}

/* 推荐训练卡片 */
.plans-scroll {
  margin: 0 -24rpx;
  padding: 0 24rpx;
}

.plans-list {
  display: flex;
  gap: 20rpx;
  padding-right: 24rpx;
}

.plan-card {
  flex-shrink: 0;
  width: 300rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.plan-hover {
  transform: translateY(-8rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
}

.plan-image-box {
  position: relative;
  height: 160rpx;
  background: linear-gradient(135deg, #e0f2fe, #dbeafe);
}

.plan-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.9;
}

.plan-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #ffffff;
}

.plan-badge.beginner {
  background: linear-gradient(135deg, #10b981, #059669);
}

.plan-badge.intermediate {
  background: linear-gradient(135deg, #f59e0b, #ea580c);
}

.plan-badge.advanced {
  background: linear-gradient(135deg, #ef4444, #dc2626);
}

.plan-duration {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

.duration-icon {
  width: 18rpx;
  height: 18rpx;
}

.duration-text {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 500;
}

.plan-info {
  padding: 24rpx;
}

.plan-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}

.plan-category {
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 16rpx;
  display: block;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
  font-weight: 500;
}

.plan-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.plan-calories {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: #fef3f2;
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
}

.cal-icon {
  width: 18rpx;
  height: 18rpx;
}

.cal-text {
  font-size: 20rpx;
  color: #ea580c;
  font-weight: 600;
}

.plan-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.star-icon {
  width: 20rpx;
  height: 20rpx;
}

.rating-num {
  font-size: 22rpx;
  font-weight: 600;
  color: #64748b;
}

/* 本周数据 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #10b981, #059669);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s ease;
}

.stat-card:active::before {
  transform: scaleX(1);
}

.stat-card.streak::before {
  background: linear-gradient(90deg, #f59e0b, #ea580c);
}

.stat-hover {
  transform: translateY(-6rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.12);
}

.stat-hover::before {
  transform: scaleX(1);
}

.stat-icon-img {
  width: 44rpx;
  height: 44rpx;
  display: block;
  margin: 0 auto 16rpx;
  opacity: 0.9;
}

.stat-number {
  font-size: 52rpx;
  font-weight: 700;
  color: #0f172a;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1;
}

.stat-name {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

.bottom-safe {
  height: 40rpx;
}
