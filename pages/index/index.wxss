/**index.wxss**/
.page-container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 20rpx;
}

/* 欢迎区域 */
.welcome-section {
  margin-bottom: 30rpx;
}

.welcome-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-greeting {
  flex: 1;
}

.greeting-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.greeting-subtitle {
  font-size: 26rpx;
  color: #555555;
  display: block;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.avatar-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 今日目标卡片 */
.goal-card {
  background: linear-gradient(135deg, #07c160, #06a552);
  color: #ffffff;
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
}

.goal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 2;
}

.goal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.3);
}

.goal-progress {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.3);
}

.goal-content {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 2;
}

.goal-item {
  flex: 1;
  text-align: center;
}

.goal-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.95);
  display: block;
  margin-bottom: 8rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.goal-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.3);
}

.progress-bar {
  height: 8rpx;
  background-color: rgba(255, 255, 255, 0.25);
  border-radius: 4rpx;
  overflow: hidden;
  box-shadow: inset 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 2;
}

.progress-fill {
  height: 100%;
  background-color: #ffffff;
  border-radius: 4rpx;
  transition: width 0.3s ease;
  box-shadow: 0 0 8rpx rgba(255, 255, 255, 0.5);
}

/* 快速开始区域 */
.quick-start-section {
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  font-size: 26rpx;
  color: #07c160;
  font-weight: 500;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.action-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.action-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
  display: block;
}

.action-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #666666;
  font-weight: 500;
  display: block;
}

/* 推荐训练区域 */
.recommended-section {
  margin-bottom: 30rpx;
}

.recommended-scroll {
  white-space: nowrap;
}

.recommended-list {
  display: flex;
  gap: 20rpx;
  padding-bottom: 10rpx;
}

.recommended-card {
  flex-shrink: 0;
  width: 280rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.recommended-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.plan-image {
  position: relative;
  margin-bottom: 16rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #f0f2f5;
}

.plan-cover {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.plan-difficulty {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background-color: rgba(255, 255, 255, 0.9);
  color: #333333;
  font-size: 22rpx;
  font-weight: bold;
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(10rpx);
}

.plan-info {
  white-space: normal;
}

.plan-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.plan-duration,
.plan-calories {
  font-size: 24rpx;
  color: #555555;
  font-weight: 500;
}

.plan-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.rating-text {
  font-size: 24rpx;
  color: #ff9500;
  font-weight: bold;
}

.rating-count {
  font-size: 22rpx;
  color: #777777;
  font-weight: 500;
}

/* 统计数据区域 */
.stats-section {
  margin-bottom: 30rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.stat-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #07c160;
  display: block;
  margin-bottom: 8rpx;
  text-shadow: 0 1rpx 2rpx rgba(7, 193, 96, 0.1);
}

.stat-label {
  font-size: 26rpx;
  color: #555555;
  font-weight: 500;
  display: block;
}
