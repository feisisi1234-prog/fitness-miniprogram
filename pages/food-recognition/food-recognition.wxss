/* pages/food-recognition/food-recognition.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 20rpx;
}

/* 上传区域 */
.upload-area {
  margin-top: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ffffff, #f8f9fa);
  border-radius: 32rpx;
  padding: 120rpx 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  border: 3rpx dashed rgba(7, 193, 96, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: uploadFadeIn 0.6s ease;
}

@keyframes uploadFadeIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.upload-area:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
  border-color: rgba(7, 193, 96, 0.5);
}

.upload-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
  animation: float 3s ease-in-out infinite;
}

.grid-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 12rpx;
  opacity: 0.8;
}

.label-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.grid-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.grid-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #07c160;
}

.suggestion-item {
  background: rgba(255, 159, 64, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 0;
}

.suggestion-value {
  line-height: 1.8;
  color: #555;
}

.bottom-actions {
  margin-top: 30rpx;
}

.bottom-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #007aff, #0066cc);
  color: #fff;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.3);
  transition: all 0.3s ease;
}

.bottom-btn:active {
  transform: scale(0.95);
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-content {
  background: linear-gradient(135deg, #ffffff, #f8f9fa);
  border-radius: 24rpx;
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(7, 193, 96, 0.2);
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.loading-hint {
  font-size: 26rpx;
  color: #999;
}
