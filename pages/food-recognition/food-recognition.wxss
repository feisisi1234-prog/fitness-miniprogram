/* pages/food-recognition/food-recognition.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 20rpx;
}

/* 上传区域 */
.upload-area {
  margin-top: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ffffff, #f8f9fa);
  border-radius: 32rpx;
  padding: 120rpx 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  border: 3rpx dashed rgba(7, 193, 96, 0.3);
  transition: all 0.3s ease;
}

.upload-area:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.upload-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.upload-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.upload-hint {
  font-size: 28rpx;
  color: #999;
}

/* 预览区域 */
.preview-area {
  margin-top: 40rpx;
}

.preview-image {
  width: 100%;
  height: 600rpx;
  border-radius: 24rpx;
  background: #f0f0f0;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.reselect-btn {
  background: linear-gradient(135deg, #868e96, #495057);
  color: #fff;
}

.recognize-btn {
  background: linear-gradient(135deg, #07c160, #06a552);
  color: #fff;
}

.recognize-btn[disabled] {
  background: #cccccc;
  opacity: 0.6;
}

/* 结果区域 */
.result-area {
  margin-top: 40rpx;
}

.result-image-wrapper {
  margin-bottom: 30rpx;
}

.result-image {
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
  background: #f0f0f0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.result-card {
  background: linear-gradient(135deg, #ffffff, #f8f9fa);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 30rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.05);
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.result-badge {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #07c160, #06a552);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.result-item {
  margin-bottom: 30rpx;
}

.result-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.label-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.result-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.name-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #07c160;
}

.result-divider {
  height: 1rpx;
  background: rgba(0, 0, 0, 0.05);
  margin: 30rpx 0;
}

.result-grid {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.result-grid-item {
  flex: 1;
  background: rgba(7, 193, 96, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.grid-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.grid-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.grid-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #07c160;
}

.suggestion-item {
  background: rgba(255, 159, 64, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 0;
}

.suggestion-value {
  line-height: 1.8;
  color: #555;
}

.bottom-actions {
  margin-top: 30rpx;
}

.bottom-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #007aff, #0066cc);
  color: #fff;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.3);
  transition: all 0.3s ease;
}

.bottom-btn:active {
  transform: scale(0.95);
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-content {
  background: linear-gradient(135deg, #ffffff, #f8f9fa);
  border-radius: 24rpx;
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(7, 193, 96, 0.2);
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.loading-hint {
  font-size: 26rpx;
  color: #999;
}
