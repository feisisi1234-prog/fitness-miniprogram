/* pages/body-tracking/body-tracking.wxss */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #fef3f2 100%);
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1e293b;
}

.add-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  border-radius: 20rpx;
  font-size: 28rpx;
  border: none;
}

.add-btn::after {
  border: none;
}

/* 标签页 */
.tabs-scroll {
  margin-bottom: 24rpx;
}

.data-tabs {
  display: flex;
  gap: 12rpx;
  white-space: nowrap;
}

.tab-item {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  background: #ffffff;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #64748b;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  font-weight: 600;
}

/* 统计卡片 */
.stats-card {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 8rpx;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.stat-value.increase {
  color: #ef4444;
}

.stat-value.decrease {
  color: #10b981;
}

.stat-unit {
  font-size: 24rpx;
  color: #94a3b8;
  margin-left: 4rpx;
}

/* 图表卡片 */
.chart-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.chart-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 24rpx;
}

.simple-chart {
  height: 300rpx;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 240rpx;
  gap: 4rpx;
  margin-bottom: 12rpx;
}

.chart-bar {
  flex: 1;
  display: flex;
  align-items: flex-end;
  min-height: 20rpx;
}

.bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #10b981 0%, #059669 100%);
  border-radius: 4rpx 4rpx 0 0;
  min-height: 8rpx;
}

.chart-labels {
  display: flex;
  justify-content: space-between;
  gap: 4rpx;
}

.chart-label {
  flex: 1;
  font-size: 20rpx;
  color: #94a3b8;
  text-align: center;
}

/* 历史记录 */
.records-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 20rpx;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.record-data {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.record-actions {
  margin-left: 16rpx;
}

.delete-btn {
  font-size: 26rpx;
  color: #ef4444;
  padding: 8rpx 16rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

.empty-hint {
  display: block;
  font-size: 26rpx;
  color: #94a3b8;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
}

.modal-close {
  font-size: 48rpx;
  color: #94a3b8;
  line-height: 1;
}

.modal-body {
  max-height: 60vh;
  overflow-y: auto;
  padding: 28rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

.form-input, .picker-value {
  width: 100%;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1e293b;
  border: 1rpx solid #e2e8f0;
}

.picker-value {
  display: block;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 28rpx;
  border-top: 1rpx solid #f1f5f9;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  border: none;
}

.cancel-btn {
  background: #f1f5f9;
  color: #64748b;
}

.confirm-btn {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
}

.cancel-btn::after, .confirm-btn::after {
  border: none;
}
