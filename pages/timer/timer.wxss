/**timer.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--bg-secondary);
}

.container {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

/* 计时器显示 */
.timer-display {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 40rpx 0;
  position: relative;
  animation: timerFadeIn 0.8s ease;
}

@keyframes timerFadeIn {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.timer-circle {
  width: 420rpx;
  height: 420rpx;
  border-radius: 210rpx;
  background: linear-gradient(135deg, var(--bg-primary), #f8f9fa);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: var(--shadow-lg);
  position: relative;
  overflow: hidden;
  animation: timerPulse 2s ease-in-out infinite;
}

@keyframes timerPulse {
  0%, 100% {
    box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  }
  50% {
    box-shadow: 0 12rpx 32rpx rgba(7, 193, 96, 0.2);
  }
}

.timer-circle::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
}

.timer-text {
  font-size: 70rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 20rpx;
  font-family: 'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', Consolas, 'Courier New', monospace;
}

.timer-status {
  font-size: 30rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.calories-display {
  position: absolute;
  right: 40rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, rgba(255, 149, 0, 0.1), rgba(255, 149, 0, 0.2));
  padding: 24rpx;
  border-radius: 24rpx;
  box-shadow: var(--shadow);
  border: 2rpx solid rgba(255, 149, 0, 0.2);
}

.calories-text {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--secondary-color);
}

.calories-label {
  font-size: 26rpx;
  color: var(--secondary-color);
  margin-top: 8rpx;
  font-weight: 500;
}

/* 计时器控制 */
.timer-controls {
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx;
  gap: 20rpx;
  animation: controlsFadeIn 0.6s ease 0.2s both;
}

@keyframes controlsFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.control-btn {
  width: 180rpx;
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #ffffff;
  box-shadow: var(--shadow);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.control-btn::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.control-btn:active::before {
  width: 300rpx;
  height: 300rpx;
}

.control-btn:active {
  transform: scale(0.95);
}

.control-btn.start {
  background: linear-gradient(135deg, var(--primary-color), #06a552);
}

.control-btn.pause {
  background: linear-gradient(135deg, var(--secondary-color), #ff8010);
}

.control-btn.reset {
  background: linear-gradient(135deg, #8e8e93, #6d6d70);
}

.control-btn.lap {
  background: linear-gradient(135deg, var(--accent-color), #0066cc);
}

.control-btn.finish {
  background: linear-gradient(135deg, var(--danger-color), #d12b20);
}

/* 语音设置 */
.voice-settings {
  margin-bottom: 40rpx;
}

.voice-control {
  background: linear-gradient(135deg, var(--bg-primary), #f8f9fa);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: var(--shadow);
}

.voice-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.voice-label {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.voice-switch {
  transform: scale(1.2);
}

.voice-interval {
  margin-top: 20rpx;
}

.interval-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  display: block;
}

.interval-options {
  display: flex;
  justify-content: space-between;
  gap: 15rpx;
}

.interval-option {
  flex: 1;
  height: 70rpx;
  background: linear-gradient(135deg, #f0f0f0, #e6e6e6);
  border-radius: 35rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.3s ease;
  font-weight: 500;
}

.interval-option.active {
  background: linear-gradient(135deg, var(--primary-color), #06a552);
  color: #fff;
  box-shadow: var(--shadow-sm);
}

.interval-option:active {
  transform: scale(0.95);
}

/* 预设时间 */
.preset-times {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  color: var(--text-primary);
  display: flex;
  align-items: center;
}

.section-title::before {
  content: "⏱";
  margin-right: 16rpx;
  font-size: 36rpx;
}

.preset-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.preset-item {
  width: calc(33.33% - 14rpx);
  height: 90rpx;
  background: linear-gradient(135deg, var(--bg-primary), #f8f9fa);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--text-primary);
  box-shadow: var(--shadow);
  transition: all 0.3s ease;
  font-weight: 500;
}

.preset-item:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-lg);
}

/* 记录列表 */
.lap-times {
  flex: 1;
  margin-bottom: 40rpx;
  min-height: 200rpx;
}

.lap-list {
  max-height: 300rpx;
  background: linear-gradient(135deg, var(--bg-primary), #f8f9fa);
  border-radius: 24rpx;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.lap-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid var(--border-color);
  transition: all 0.3s ease;
}

.lap-item:last-child {
  border-bottom: none;
}

.lap-item:active {
  background-color: rgba(7, 193, 96, 0.05);
}

.lap-index {
  font-size: 30rpx;
  color: var(--text-muted);
  font-weight: 500;
}

.lap-time {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--primary-color);
  font-family: 'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', Consolas, 'Courier New', monospace;
}

.lap-calories {
  font-size: 30rpx;
  color: var(--secondary-color);
  font-weight: 500;
}

/* 运动类型 */
.exercise-type {
  margin-bottom: 40rpx;
}

.type-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.type-item {
  width: calc(33.33% - 14rpx);
  height: 160rpx;
  background: linear-gradient(135deg, var(--bg-primary), #f8f9fa);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.type-item::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
  opacity: 0;
  transition: opacity 0.3s ease;
}

.type-item.active {
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.1), rgba(7, 193, 96, 0.2));
  border: 2rpx solid var(--primary-color);
}

.type-item.active::before {
  opacity: 1;
}

.type-item:active {
  transform: scale(0.95);
}

.type-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 16rpx;
}

.type-item text {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.calories-rate {
  font-size: 22rpx !important;
  color: var(--text-muted) !important;
  margin-top: 8rpx;
  font-weight: normal !important;
}