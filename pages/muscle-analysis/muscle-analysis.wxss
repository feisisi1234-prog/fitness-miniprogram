/* 人体图容器 - 支持3D效果 */
.model-viewer {
  position: relative;
  width: 100%;
  min-height: 800rpx;
  perspective: 2000rpx;
  overflow: hidden;
}

/* 人体图 - 3D翻转效果 */
.human-body-diagram {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.6s ease;
  transform-style: preserve-3d;
  backface-visibility: hidden;
}

.human-body-diagram.show {
  opacity: 1;
  transform: rotateY(0deg);
  z-index: 2;
}

.human-body-diagram.hide {
  opacity: 0;
  pointer-events: none;
  z-index: 1;
}

/* 背面视图特殊样式 */
.human-body-diagram.back-view .body-svg-container {
  transform: scaleX(-1);
}

.human-body-diagram.back-view .muscle-label {
  transform: scaleX(-1);
}

/* 滑动提示 */
.swipe-hint {
  position: absolute;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.7);
  color: #ffffff;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  animation: fadeInOut 3s ease-in-out infinite;
  z-index: 10;
}

.hint-icon {
  font-size: 32rpx;
  animation: swipeAnimation 2s ease-in-out infinite;
}

.hint-text {
  font-size: 24rpx;
}

@keyframes fadeInOut {
  0%, 100% {
    opacity: 0.6;
  }
  50% {
    opacity: 1;
  }
}

@keyframes swipeAnimation {
  0%, 100% {
    transform: translateX(0);
  }
  50% {
    transform: translateX(10rpx);
  }
}

