  position: absolute;
  top: 40rpx;
  width: 50rpx;
  height: 80rpx;
  background: radial-gradient(ellipse at center, 
    rgba(255, 255, 255, 0.12) 0%,
    transparent 70%
  );
  border-radius: 50%;
}

.leg-upper-left::before {
  left: 3rpx;
}

.leg-upper-right::before {
  right: 3rpx;
}

/* 小腿 */
.leg-lower-left,
.leg-lower-right {
  width: 50rpx !important;
  height: 150rpx !important;
  background: linear-gradient(135deg, #ffa64d 0%, #ff8c1a 100%) !important;
  border-radius: 25rpx !important;
  box-shadow: 
    inset -3rpx 0 8rpx rgba(0, 0, 0, 0.12),
    0 4rpx 10rpx rgba(0, 0, 0, 0.15) !important;
  margin-top: -3rpx !important;
  margin-left: 5rpx !important;
  position: relative !important;
}

/* 小腿肌肉凸起 */
.leg-lower-left::before,
.leg-lower-right::before {
  content: '';
  position: absolute;
  top: 30rpx;
  width: 40rpx;
  height: 60rpx;
  background: radial-gradient(ellipse at center, 
    rgba(255, 255, 255, 0.12) 0%,
    transparent 70%
  );
  border-radius: 50%;
}

.leg-lower-left::before {
  left: 3rpx;
}

.leg-lower-right::before {
  right: 3rpx;
}

/* 脚部 */
.foot-left,
.foot-right {
  width: 65rpx !important;
  height: 35rpx !important;
  background: linear-gradient(135deg, #ffcc99 0%, #ffb380 100%) !important;
  border-radius: 18rpx 18rpx 12rpx 12rpx !important;
  box-shadow: 
    inset 0 -4rpx 8rpx rgba(0, 0, 0, 0.1),
    0 3rpx 8rpx rgba(0, 0, 0, 0.15) !important;
  margin-top: -3rpx !important;
  margin-left: -8rpx !important;
}

/* ========== 背面视图特殊样式 ========== */
.back-view .back-upper {
  position: absolute;
  top: 165rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 180rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #ffb380 0%, #ff9966 50%, #ff8040 100%);
  border-radius: 90rpx 90rpx 40rpx 40rpx;
  box-shadow: 
    inset 0 -20rpx 30rpx rgba(0, 0, 0, 0.12),
    0 6rpx 15rpx rgba(0, 0, 0, 0.15);
  z-index: 2;
}

/* 脊柱线条 */
.back-view .back-upper::before {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: 100rpx;
  background: linear-gradient(180deg, 
    rgba(0, 0, 0, 0) 0%,
    rgba(0, 0, 0, 0.15) 50%,
    rgba(0, 0, 0, 0) 100%
  );
}

.back-view .back-lower {
  position: absolute;
  top: 295rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #ffb380 0%, #ff9966 50%, #ff8040 100%);
  border-radius: 30rpx;
  box-shadow: 
    inset 0 -15rpx 25rpx rgba(0, 0, 0, 0.12),
    0 6rpx 15rpx rgba(0, 0, 0, 0.15);
  z-index: 2;
}

.back-view .gluteus {
  position: absolute;
  top: 445rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 150rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #ff9966 0%, #ff7733 100%);
  border-radius: 75rpx 75rpx 40rpx 40rpx;
  box-shadow: 
    inset 0 -12rpx 20rpx rgba(0, 0, 0, 0.15),
    0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  z-index: 2;
}

/* 臀部肌肉分隔 */
.back-view .gluteus::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: 70rpx;
  background: linear-gradient(180deg, 
    rgba(0, 0, 0, 0) 0%,
    rgba(0, 0, 0, 0.15) 50%,
    rgba(0, 0, 0, 0) 100%
  );
}


/* 肌肉分布图示样式 */
.muscle-diagram {
  width: 100%;
  min-height: 400rpx;
  background: linear-gradient(135deg, #f8f9fa, #e9ecef);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin: 20rpx 0;
  padding: 40rpx 30rpx;
}

.diagram-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.diagram-icon {
  font-size: 120rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.1));
}

.diagram-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
}

.muscle-groups {
  display: flex;
  gap: 20rpx;
  width: 100%;
  justify-content: center;
  flex-wrap: wrap;
}

.muscle-group-item {
  flex: 1;
  min-width: 180rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #e0e0e0;
}

.group-icon {
  font-size: 48rpx;
}

.group-name {
  font-size: 26rpx;
  color: #555555;
  font-weight: 500;
  text-align: center;
}

.diagram-note {
  font-size: 24rpx;
  color: #777777;
  text-align: center;
  line-height: 1.6;
  padding: 0 20rpx;
}

