.container {
  padding: 20rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

/* 标签页样式 */
.tabs {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.tabs::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(135deg, #07c160, #06a552);
  border-radius: 16rpx 16rpx 0 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 32rpx 0;
  font-size: 32rpx;
  color: #666666;
  position: relative;
  transition: all 0.3s ease;
  font-weight: 500;
}

.tab-item.active {
  color: #07c160;
  font-weight: bold;
  background: rgba(7, 193, 96, 0.1);
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 6rpx;
  background: linear-gradient(135deg, #07c160, #06a552);
  border-radius: 3rpx 3rpx 0 0;
}

/* 标签页内容 */
.tab-content {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
}

.tab-content::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(135deg, #ff9500, #e6850e);
  border-radius: 16rpx 16rpx 0 0;
}

/* 3D模型区域样式 */
.model-container {
  width: 100%;
  min-height: 600rpx;
  background: linear-gradient(135deg, #ffffff, #f8f9fa);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  position: relative;
  overflow: visible;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #e0e0e0;
  padding: 20rpx 0;
}

.diagram-title {
  text-align: center;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.diagram-title text:first-child {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.diagram-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.model-viewer {
  width: 100%;
  height: 100%;
  position: relative;
}

.human-body-diagram {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 20rpx;
}

.body-svg-container {
  width: 360rpx;
  height: 700rpx;
  position: relative;
  margin: 0 auto;
}

/* 人体轮廓部分 - 改进版 */
.body-part {
  position: absolute;
  background: linear-gradient(135deg, #f5e6d3, #e8d4bd);
  border: 2rpx solid #d4b896;
}

.head {
  width: 90rpx;
  height: 110rpx;
  border-radius: 45rpx 45rpx 50rpx 50rpx;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #ffeedd, #f5d5b8);
}

.neck {
  width: 50rpx;
  height: 35rpx;
  top: 105rpx;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 10rpx;
  background: linear-gradient(135deg, #f5e6d3, #e8d4bd);
}

/* 肩部 */
.shoulder-left, .shoulder-right {
  width: 70rpx;
  height: 50rpx;
  top: 135rpx;
  border-radius: 35rpx 35rpx 10rpx 10rpx;
  background: linear-gradient(135deg, #f5d5b8, #e8c4a8);
}

.shoulder-left {
  left: 50rpx;
}

.shoulder-right {
  right: 50rpx;
}

/* 胸部 */
.chest {
  width: 140rpx;
  height: 100rpx;
  top: 140rpx;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 20rpx 20rpx 10rpx 10rpx;
  background: linear-gradient(135deg, #f5e6d3, #e8d4bd);
}

/* 腹部 */
.abdomen {
  width: 130rpx;
  height: 110rpx;
  top: 235rpx;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 10rpx 10rpx 15rpx 15rpx;
  background: linear-gradient(135deg, #f5e6d3, #e8d4bd);
}

/* 骨盆 */
.pelvis {
  width: 140rpx;
  height: 70rpx;
  top: 340rpx;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 15rpx 15rpx 70rpx 70rpx;
  background: linear-gradient(135deg, #f5d5b8, #e8c4a8);
}

/* 左臂 */
.arm-left {
  position: absolute;
  top: 165rpx;
  left: 25rpx;
}

.arm-upper-left {
  width: 38rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #f5e6d3, #e8d4bd);
  border: 2rpx solid #d4b896;
  border-radius: 19rpx;
  transform: rotate(-8deg);
  transform-origin: top center;
}

.arm-lower-left {
  width: 35rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #f5e6d3, #e8d4bd);
  border: 2rpx solid #d4b896;
  border-radius: 17rpx;
  transform: rotate(12deg);
  transform-origin: top center;
  margin-top: -2rpx;
  margin-left: 2rpx;
}

.hand-left {
  width: 30rpx;
  height: 35rpx;
  background: linear-gradient(135deg, #ffeedd, #f5d5b8);
  border: 2rpx solid #d4b896;
  border-radius: 15rpx 15rpx 20rpx 20rpx;
  margin-top: -2rpx;
  margin-left: 3rpx;
}

/* 右臂 */
.arm-right {
  position: absolute;
  top: 165rpx;
  right: 25rpx;
}

.arm-upper-right {
  width: 38rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #f5e6d3, #e8d4bd);
  border: 2rpx solid #d4b896;
  border-radius: 19rpx;
  transform: rotate(8deg);
  transform-origin: top center;
}

.arm-lower-right {
  width: 35rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #f5e6d3, #e8d4bd);
  border: 2rpx solid #d4b896;
  border-radius: 17rpx;
  transform: rotate(-12deg);
  transform-origin: top center;
  margin-top: -2rpx;
  margin-left: 1rpx;
}

.hand-right {
  width: 30rpx;
  height: 35rpx;
  background: linear-gradient(135deg, #ffeedd, #f5d5b8);
  border: 2rpx solid #d4b896;
  border-radius: 15rpx 15rpx 20rpx 20rpx;
  margin-top: -2rpx;
}

/* 左腿 */
.leg-left {
  position: absolute;
  top: 405rpx;
  left: 95rpx;
}

.leg-upper-left {
  width: 50rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #f5e6d3, #e8d4bd);
  border: 2rpx solid #d4b896;
  border-radius: 25rpx 25rpx 20rpx 20rpx;
}

.leg-lower-left {
  width: 45rpx;
  height: 130rpx;
  background: linear-gradient(135deg, #f5e6d3, #e8d4bd);
  border: 2rpx solid #d4b896;
  border-radius: 22rpx;
  margin-top: -2rpx;
  margin-left: 2rpx;
}

.foot-left {
  width: 55rpx;
  height: 30rpx;
  background: linear-gradient(135deg, #ffeedd, #f5d5b8);
  border: 2rpx solid #d4b896;
  border-radius: 15rpx 15rpx 10rpx 10rpx;
  margin-top: -2rpx;
  margin-left: -5rpx;
}

/* 右腿 */
.leg-right {
  position: absolute;
  top: 405rpx;
  right: 95rpx;
}

.leg-upper-right {
  width: 50rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #f5e6d3, #e8d4bd);
  border: 2rpx solid #d4b896;
  border-radius: 25rpx 25rpx 20rpx 20rpx;
}

.leg-lower-right {
  width: 45rpx;
  height: 130rpx;
  background: linear-gradient(135deg, #f5e6d3, #e8d4bd);
  border: 2rpx solid #d4b896;
  border-radius: 22rpx;
  margin-top: -2rpx;
  margin-left: 3rpx;
}

.foot-right {
  width: 55rpx;
  height: 30rpx;
  background: linear-gradient(135deg, #ffeedd, #f5d5b8);
  border: 2rpx solid #d4b896;
  border-radius: 15rpx 15rpx 10rpx 10rpx;
  margin-top: -2rpx;
}

/* 肌肉标注 */
.muscle-label {
  position: absolute;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  cursor: pointer;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.3;
  z-index: 10;
}

.muscle-label.active {
  opacity: 1;
  transform: scale(1.05);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.3);
  animation: musclePulse 1.5s ease-in-out infinite;
}

@keyframes musclePulse {
  0%, 100% { 
    transform: scale(1.05);
    box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.3);
  }
  50% { 
    transform: scale(1.1);
    box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
  }
}

.muscle-name {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
  padding: 4rpx 8rpx;
  text-align: center;
}

/* 三角肌 - 覆盖肩部，鲜艳红色 */
.deltoid-muscle {
  width: 130rpx;
  height: 80rpx;
  top: 145rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #ff4757, #ff3838);
  border-radius: 40rpx 40rpx 10rpx 10rpx;
}

/* 胸大肌 - 鲜艳橙色 */
.pectoralis-muscle {
  width: 120rpx;
  height: 85rpx;
  top: 155rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #ff6348, #ff4757);
  border-radius: 15rpx 15rpx 8rpx 8rpx;
}

/* 腹直肌 - 鲜艳黄色 */
.rectus-muscle {
  width: 110rpx;
  height: 95rpx;
  top: 245rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #ffa502, #ff9500);
  border-radius: 10rpx;
}

/* 臀大肌 - 鲜艳蓝色 */
.gluteus-muscle {
  width: 130rpx;
  height: 65rpx;
  top: 345rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #3742fa, #2f3542);
  border-radius: 65rpx 65rpx 10rpx 10rpx;
}

/* 肱二头肌 - 鲜艳绿色 */
.biceps-muscle {
  width: 50rpx;
  height: 95rpx;
  top: 195rpx;
  left: 35rpx;
  background: linear-gradient(135deg, #2ed573, #1e90ff);
  border-radius: 25rpx;
  transform: rotate(-8deg);
}

/* 股四头肌 - 鲜艳紫色 */
.quadriceps-muscle {
  width: 80rpx;
  height: 130rpx;
  top: 420rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #a29bfe, #6c5ce7);
  border-radius: 40rpx 40rpx 20rpx 20rpx;
}


/* 肌肉详情弹窗 */
.muscle-detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  width: 80%;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  animation: modalShow 0.3s ease-out;
}

@keyframes modalShow {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #07c160, #06a552);
  color: white;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
}

.close-btn {
  background: none;
  border: none;
  color: white;
  font-size: 40rpx;
  line-height: 1;
  padding: 0;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-body {
  padding: 30rpx;
}

.detail-row {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.detail-label {
  width: 160rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

/* 肌纤维走向页面样式 */
.action-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.action-item {
  width: calc(33.333% - 14rpx);
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
}

.action-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(135deg, #ff9500, #e6850e);
  border-radius: 16rpx 16rpx 0 0;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.action-item.active {
  background: rgba(7, 193, 96, 0.1);
  border: 2rpx solid #07c160;
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.action-item.active::before {
  opacity: 1;
}

.action-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.muscle-group {
  font-size: 24rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-detail {
  border-top: 1rpx solid #eaeaea;
  padding-top: 36rpx;
}

.detail-header {
  text-align: center;
  margin-bottom: 36rpx;
}

.detail-title {
  display: block;
  font-size: 38rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.detail-subtitle {
  font-size: 30rpx;
  color: #07c160;
}

.detail-content {
  padding: 0 20rpx;
}

.detail-section {
  margin-bottom: 36rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 18rpx;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #07c160, #06a552);
  border-radius: 3rpx;
}

.section-content {
  font-size: 30rpx;
  line-height: 1.6;
  color: #666666;
}

.detail-image {
  display: flex;
  justify-content: center;
  margin-top: 36rpx;
}

.muscle-image {
  width: 80%;
  height: 400rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.image-placeholder {
  width: 100%;
  min-height: 300rpx;
  background: linear-gradient(135deg, #f8f9fa, #e9ecef);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40rpx 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  border: 2rpx dashed #dee2e6;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.placeholder-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.placeholder-note {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
  text-align: center;
  line-height: 1.6;
}

.placeholder-desc {
  font-size: 28rpx;
  color: #07c160;
  margin-top: 20rpx;
  padding: 20rpx;
  background: rgba(7, 193, 96, 0.1);
  border-radius: 12rpx;
  text-align: center;
  line-height: 1.6;
  max-width: 100%;
}

/* 肌肉张力计算页面样式 */
.knowledge-section {
  background: linear-gradient(135deg, #ffffff, #f8f9fa);
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
}

.knowledge-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #17a2b8, #138496);
  border-radius: 20rpx 20rpx 0 0;
}

.knowledge-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.05);
}

.knowledge-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.knowledge-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.knowledge-content {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.knowledge-item {
  background: rgba(23, 162, 184, 0.05);
  padding: 24rpx;
  border-radius: 16rpx;
  border-left: 4rpx solid #17a2b8;
}

.knowledge-subtitle {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #17a2b8;
  margin-bottom: 16rpx;
}

.knowledge-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.factor-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 12rpx;
}

.factor-item {
  display: flex;
  align-items: flex-start;
  background: rgba(255, 255, 255, 0.8);
  padding: 16rpx;
  border-radius: 12rpx;
}

.factor-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.factor-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}

.exercise-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 36rpx;
}

.exercise-item {
  width: 48%;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
}

.exercise-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(135deg, #007aff, #0066cc);
  border-radius: 16rpx 16rpx 0 0;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.exercise-item.active {
  background: rgba(255, 152, 0, 0.1);
  border: 2rpx solid #ff9500;
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.exercise-item.active::before {
  opacity: 1;
}

.exercise-name {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  color: #333333;
}

.target-muscle {
  font-size: 28rpx;
  color: #666666;
}

.tension-calculator {
  border-top: 1rpx solid #eaeaea;
  padding-top: 36rpx;
}

.formula-section, .data-section, .custom-calculation {
  margin-bottom: 48rpx;
}

.formula-title, .data-title, .calc-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
  position: relative;
  padding-left: 16rpx;
}

.formula-title::before, .data-title::before, .calc-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #07c160, #06a552);
  border-radius: 3rpx;
}

.formula-box {
  background: rgba(7, 193, 96, 0.08);
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border-left: 4rpx solid #07c160;
}

.formula-main {
  display: block;
  font-size: 36rpx;
  color: #07c160;
  font-weight: bold;
  margin-bottom: 16rpx;
  text-align: center;
}

.formula-detail {
