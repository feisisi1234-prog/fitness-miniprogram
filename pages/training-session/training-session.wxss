/* pages/training-session/training-session.wxss */
page {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  min-height: 100vh;
}

.training-session-container {
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: 180rpx;
}

/* 顶部信息栏 */
.header-bar {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-left {
  flex: 1;
}

.plan-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 10rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 500;
}

.header-right {
  display: flex;
  gap: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #07c160;
}

/* 当前动作信息 */
.current-exercise {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.exercise-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.exercise-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
}

.set-info {
  background: linear-gradient(135deg, #07c160 0%, #06a552 100%);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

.set-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

.exercise-image {
  width: 100%;
  height: 400rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  background: #f5f5f5;
}

.exercise-details {
  display: flex;
  gap: 30rpx;
  margin-top: 40rpx;
  margin-bottom: 20rpx;
}

.detail-item {
  flex: 1;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  padding: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.detail-icon {
  font-size: 32rpx;
}

.detail-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.exercise-description {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.description-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff9500;
  display: block;
  margin-bottom: 10rpx;
}

.description-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 休息倒计时 */
.rest-timer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.rest-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9500 0%, #ff8010 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 149, 0, 0.4);
  margin-bottom: 20rpx;
}

.rest-time {
  font-size: 80rpx;
  font-weight: bold;
  color: #ffffff;
}

.rest-label {
  font-size: 28rpx;
  color: #ffffff;
}

.rest-text {
  font-size: 32rpx;
  color: #ff9500;
  font-weight: 500;
}

/* 动作计时器 */
.exercise-timer {
  text-align: center;
  padding: 20rpx 0;
}

.timer-text {
  font-size: 60rpx;
  font-weight: bold;
  color: #07c160;
  font-family: 'SF Mono', Monaco, monospace;
}

/* 控制按钮 */
.control-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.control-btn {
  flex: 1;
  height: 90rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s;
}

.control-btn:active {
  transform: scale(0.98);
}

.primary-btn {
  background: linear-gradient(135deg, #07c160 0%, #06a552 100%);
  color: #ffffff;
}

.primary-btn[disabled] {
  background: #cccccc;
  color: #999999;
}

.secondary-btn {
  background: linear-gradient(135deg, #007aff 0%, #0066cc 100%);
  color: #ffffff;
}

.skip-btn {
  background: linear-gradient(135deg, #8e8e93 0%, #6d6d70 100%);
  color: #ffffff;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 20rpx;
  z-index: 100;
}

.bottom-btn {
  flex: 1;
  height: 90rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.bottom-btn:active {
  transform: scale(0.98);
}

.button-hover {
  opacity: 0.8;
}

.exit-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
}

.exit-btn .btn-text {
  color: #ffffff;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* 动作列表弹窗 */
.exercise-list-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  font-size: 40rpx;
  color: #999999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.exercise-list {
  max-height: 60vh;
  padding: 20rpx;
}

.exercise-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 15rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 20rpx;
  transition: all 0.3s;
}

.exercise-item:active {
  transform: scale(0.98);
}

.exercise-item.completed {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border: 2rpx solid #07c160;
}

.exercise-item.current {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  border: 2rpx solid #007aff;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.item-number {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160 0%, #06a552 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.exercise-item.completed .item-number {
  background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
}

.exercise-item.current .item-number {
  background: linear-gradient(135deg, #007aff 0%, #0066cc 100%);
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.item-detail {
  font-size: 24rpx;
  color: #999999;
}

.item-right {
  display: flex;
  align-items: center;
}

.item-status {
  font-size: 40rpx;
  color: #07c160;
}

.current-tag {
  font-size: 24rpx;
  color: #007aff;
  background: rgba(0, 122, 255, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.item-progress {
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
}
