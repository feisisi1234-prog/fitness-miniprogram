/* pages/custom-plans/custom-plans.wxss */
.container {
  padding: 24rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  min-height: 100vh;
}

/* 添加计划按钮组 */
.add-plan-buttons {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 32rpx;
}

/* 添加计划按钮 */
.add-plan-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.add-plan-btn::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.ai-btn {
  background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
  box-shadow: 0 4rpx 16rpx rgba(139, 92, 246, 0.2);
}

.ai-btn:active {
  box-shadow: 0 6rpx 20rpx rgba(139, 92, 246, 0.3);
}

.scan-btn {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.2);
}

.add-plan-btn:active {
  transform: translateY(-2rpx) scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(16, 185, 129, 0.3);
}

.scan-btn:active {
  box-shadow: 0 6rpx 20rpx rgba(59, 130, 246, 0.3);
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}

.btn-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 0.5rpx;
}

/* 计划列表 */
.plans-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.plan-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  border: 1rpx solid #f1f5f9;
}

.plan-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #10b981 0%, #3b82f6 100%);
}

.plan-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.plan-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  letter-spacing: -0.3rpx;
}

.plan-category {
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  color: #059669;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
  border: 1rpx solid rgba(16, 185, 129, 0.2);
}

/* 计划动作列表 */
.plan-exercises {
  margin-bottom: 24rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 16rpx;
}

.exercise-item {
  display: flex;
  align-items: center;
  padding: 16rpx 12rpx;
  border-bottom: 1rpx solid #e2e8f0;
  transition: background 0.2s ease;
}

.exercise-item:last-child {
  border-bottom: none;
}

.exercise-item:active {
  background: rgba(16, 185, 129, 0.05);
}

.exercise-checkbox {
  margin-right: 16rpx;
}

.exercise-content {
  flex: 1;
}

.exercise-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 6rpx;
  display: block;
}

.exercise-details {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 400;
}

/* 计划元信息 */
.plan-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: #f8fafc;
  border-radius: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  flex: 1;
}

.meta-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
  opacity: 0.6;
}

.meta-text {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.category-icon {
  width: 36rpx;
  height: 36rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 26rpx;
  color: #666666;
}

.category-option.active .category-name {
  color: #07c160;
}

/* 动作模板 */
.exercise-templates {
  margin-bottom: 30rpx;
}

.template-title {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
  display: block;
}

.template-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.template-item {
  background: rgba(7, 193, 96, 0.05);
  border: 1rpx solid rgba(7, 193, 96, 0.2);
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.template-item:active {
  background: rgba(7, 193, 96, 0.1);
  transform: scale(0.95);
}

.template-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.template-category {
  font-size: 22rpx;
  color: #999999;
}

/* 训练动作表单 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.add-exercise-btn {
  background: linear-gradient(135deg, #07c160, #007aff);
  color: #fff;
  font-size: 26rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  border: none;
}

.exercise-form-list {
  margin-top: 20rpx;
}

.exercise-form-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.exercise-form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.exercise-index {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.delete-exercise-btn {
  font-size: 26rpx;
  color: #ff6b6b;
}

.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.form-label-small {
  font-size: 26rpx;
  color: #666666;
  width: 160rpx;
}

.form-input-small {
  flex: 1;
  height: 60rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 15rpx;
  font-size: 26rpx;
  color: #333333;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
}

.image-upload {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 120rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx dashed rgba(0, 0, 0, 0.2);
}

.exercise-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.upload-tip {
  font-size: 24rpx;
  color: #999999;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
}

.cancel-btn, .save-btn {
  width: 45%;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.cancel-btn {
  background: #f8f9fa;
  color: #666666;
}

.save-btn {
  background: linear-gradient(135deg, #07c160, #007aff);
  color: #fff;
}

/* 计划操作按钮 */
.plan-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  transition: all 0.2s ease;
  letter-spacing: 0.5rpx;
}

.action-btn::after {
  border: none;
}

.start-btn {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(16, 185, 129, 0.3);
}

.start-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.4);
}

.edit-btn {
  background: #f1f5f9;
  color: #475569;
}

.edit-btn:active {
  background: #e2e8f0;
  transform: scale(0.98);
}

.delete-btn {
  background: #fef2f2;
  color: #dc2626;
}

.delete-btn:active {
  background: #fee2e2;
  transform: scale(0.98);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 32rpx;
  color: #475569;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.6;
}

/* 添加/编辑计划表单弹窗 */
.plan-form-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1;
}

.modal-content {
  position: relative;
  z-index: 2;
  width: 90%;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1e293b;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #94a3b8;
  line-height: 1;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.close-btn:active {
  background: #f1f5f9;
  color: #475569;
}

.form-scroll {
  flex: 1;
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1e293b;
  border: 2rpx solid #e2e8f0;
  transition: all 0.2s ease;
}

.form-input:focus {
  background: #ffffff;
  border-color: #10b981;
}

.category-options {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.category-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
  transition: all 0.2s ease;
}

.category-option:active {
  transform: scale(0.98);
}

.category-option.active {
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  border-color: #10b981;
}

.category-option.active .category-icon {
  filter: brightness(0) saturate(100%) invert(58%) sepia(89%) saturate(449%) hue-rotate(101deg) brightness(95%) contrast(92%);
}

.category-option.active .category-name {
  color: #059669;
  font-weight: 600;
}

/* 文字选择弹窗 */
.text-selection-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-tip {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
  border-radius: 16rpx;
  margin: 0 32rpx 24rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #9a3412;
  line-height: 1.6;
}

.selection-actions {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
}

.selection-action-btn {
  flex: 1;
  height: 64rpx;
  background: #f1f5f9;
  color: #475569;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: none;
}

.selection-action-btn:active {
  background: #e2e8f0;
}

.text-lines-scroll {
  flex: 1;
  padding: 0 32rpx;
  overflow-y: auto;
}

.text-line-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 12rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  border: 2rpx solid #e2e8f0;
  transition: all 0.2s ease;
}

.text-line-item:active {
  transform: scale(0.99);
}

.text-line-item.selected {
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  border-color: #10b981;
}

.line-checkbox {
  margin-right: 16rpx;
}

.line-text {
  flex: 1;
  font-size: 26rpx;
  color: #1e293b;
  line-height: 1.6;
}

.text-line-item.selected .line-text {
  color: #059669;
  font-weight: 500;
}
