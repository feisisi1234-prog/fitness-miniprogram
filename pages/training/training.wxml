<!--pages/training/training.wxml-->
<view class="page">
  <!-- 顶部搜索栏 -->
  <view class="search-section">
    <view class="search-box">
      <image src="/images/icons/search.svg" class="search-icon" mode="aspectFit"></image>
      <input 
        class="search-input" 
        placeholder="搜索训练计划" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
    </view>
  </view>

  <!-- 分类标签 -->
  <view class="category-section">
    <scroll-view class="category-scroll" scroll-x="true" show-scrollbar="false">
      <view class="category-list">
        <view 
          class="category-item {{currentCategory === item.id ? 'active' : ''}}" 
          wx:for="{{categories}}" 
          wx:key="id"
          bindtap="switchCategory"
          data-category="{{item.id}}"
          hover-class="category-hover"
        >
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="goToCustomPlans" hover-class="action-hover">
      <view class="action-icon-box">
        <image src="/images/icons/clipboard.svg" class="action-icon" mode="aspectFit"></image>
      </view>
      <text class="action-label">我的计划</text>
    </view>
    <view class="action-item" bindtap="goToMuscleAnalysis" hover-class="action-hover">
      <view class="action-icon-box">
        <image src="/images/icons/microscope.svg" class="action-icon" mode="aspectFit"></image>
      </view>
      <text class="action-label">肌肉分析</text>
    </view>
    <view class="action-item" bindtap="showHistoryPlans" hover-class="action-hover">
      <view class="action-icon-box">
        <image src="/images/icons/calendar.svg" class="action-icon" mode="aspectFit"></image>
      </view>
      <text class="action-label">训练记录</text>
    </view>
  </view>

  <!-- 训练计划列表 -->
  <view class="plans-section">
    <view class="section-header">
      <text class="section-title">训练计划</text>
      <picker class="sort-picker" mode="selector" range="{{['默认排序', '评分最高', '最受欢迎', '消耗最多']}}" value="{{sortType}}" bindchange="onSortChange">
        <view class="sort-btn">
          <text class="sort-text">排序</text>
          <image src="/images/icons/filter.svg" class="sort-icon" mode="aspectFit"></image>
        </view>
      </picker>
    </view>

    <view class="plans-list">
      <view 
        class="plan-card" 
        wx:for="{{filteredPlans}}" 
        wx:key="id"
        bindtap="goToPlanDetail"
        data-id="{{item.id}}"
        hover-class="plan-hover"
      >
        <view class="plan-header">
          <view class="plan-icon-box">
            <image src="{{item.icon}}" class="plan-icon" mode="aspectFit"></image>
          </view>
          <view class="plan-badge {{item.difficulty === '初级' ? 'beginner' : item.difficulty === '中级' ? 'intermediate' : 'advanced'}}">
            {{item.difficulty}}
          </view>
        </view>

        <view class="plan-content">
          <text class="plan-title">{{item.title}}</text>
          <text class="plan-desc">{{item.description}}</text>

          <view class="plan-tags">
            <view class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">
              {{tag}}
            </view>
          </view>

          <view class="plan-meta">
            <view class="meta-item">
              <image src="/images/icons/timer.svg" class="meta-icon" mode="aspectFit"></image>
              <text class="meta-text">{{item.duration}}</text>
            </view>
            <view class="meta-item">
              <image src="/images/icons/flame.svg" class="meta-icon" mode="aspectFit"></image>
              <text class="meta-text">{{item.calories}} 千卡</text>
            </view>
            <view class="meta-item">
              <image src="/images/icons/star.svg" class="meta-icon" mode="aspectFit"></image>
              <text class="meta-text">{{item.rating}}</text>
            </view>
          </view>
        </view>

        <view class="plan-footer">
          <view class="participants">
            <text class="participants-text">{{item.formattedParticipants}} 人参与</text>
          </view>
          <view class="start-btn" catchtap="startTrainingSession" data-id="{{item.id}}" data-title="{{item.title}}">
            <text class="start-text">开始训练</text>
            <image src="/images/icons/arrow-right.svg" class="start-arrow" mode="aspectFit"></image>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{filteredPlans.length === 0}}">
        <image src="/images/icons/empty.svg" class="empty-icon" mode="aspectFit"></image>
        <text class="empty-text">暂无训练计划</text>
      </view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="bottom-safe"></view>
</view>
