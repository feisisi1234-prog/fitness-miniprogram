/* 往期计划弹窗 */
.history-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-content {
  position: relative;
  width: 90%;
  max-height: 80vh;
  background: linear-gradient(135deg, #fff, #f8f9fa);
  border-radius: 24rpx;
  overflow: hidden;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #17a2b8, #138496);
  color: #fff;
}

.history-title {
  font-size: 36rpx;
  font-weight: bold;
}

.history-scroll {
  flex: 1;
  padding: 20rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.history-date-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.history-date {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.history-weekday {
  font-size: 26rpx;
  color: #666;
  background: rgba(23, 162, 184, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.history-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16rpx;
}

.history-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #17a2b8;
}

.history-records {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.record-tag {
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.1), rgba(7, 193, 96, 0.15));
  color: #07c160;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.history-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.history-empty .empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.history-empty .empty-text {
  font-size: 30rpx;
  color: #999;
}
