/* pages/ai-recommendation/ai-recommendation.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #fef3f2 100%);
  padding: 24rpx;
  padding-bottom: 180rpx;
}

/* 进度指示器 */
.progress-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  padding: 0 40rpx;
}

.progress-step {
  display: flex;
  align-items: center;
  flex: 1;
}

.step-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #e5e7eb;
  transition: all 0.3s ease;
}

.progress-step.active .step-dot {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.step-line {
  flex: 1;
  height: 4rpx;
  background: #e5e7eb;
  margin: 0 8rpx;
}

.progress-step.active .step-line {
  background: linear-gradient(90deg, #10b981 0%, #059669 100%);
}

/* 步骤内容 */
.step-content {
  animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.step-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.step-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 16rpx;
}

.step-desc {
  font-size: 28rpx;
  color: #64748b;
  display: block;
}

/* 选项列表 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 3rpx solid #e5e7eb;
  transition: all 0.3s ease;
  position: relative;
}

.option-card:active {
  transform: scale(0.98);
}

.option-card.selected {
  border-color: #10b981;
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.2);
}

.option-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.option-content {
  flex: 1;
}

.option-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 8rpx;
}

.option-desc {
  font-size: 26rpx;
  color: #64748b;
  display: block;
}

.option-check {
  width: 48rpx;
  height: 48rpx;
  background: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

/* 目标网格 */
.options-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.goal-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  border: 3rpx solid #e5e7eb;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: all 0.3s ease;
  position: relative;
  min-height: 240rpx;
}

.goal-card:active {
  transform: scale(0.98);
}

.goal-card.selected {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.goal-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.goal-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.goal-desc {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.goal-check {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

/* 时长选择器 */
.duration-selector {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.duration-label {
  font-size: 28rpx;
  color: #64748b;
  display: block;
  margin-bottom: 16rpx;
  text-align: center;
}

.duration-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #10b981;
  text-align: center;
  margin-bottom: 32rpx;
}

.duration-slider {
  width: 100%;
  margin-bottom: 16rpx;
}

.duration-marks {
  display: flex;
  justify-content: space-between;
}

.mark {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 器材网格 */
.equipment-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.equipment-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  border: 3rpx solid #e5e7eb;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  transition: all 0.3s ease;
  position: relative;
  min-height: 200rpx;
  box-sizing: border-box;
}

.equipment-card-hover {
  transform: scale(0.98);
}

.equipment-card.selected {
  border-color: #10b981;
  border-width: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.2);
}

.equipment-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  display: block;
  pointer-events: none;
}

.equipment-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  pointer-events: none;
}

.equipment-check {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  background: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  pointer-events: none;
  box-shadow: 0 2rpx 8rpx rgba(16, 185, 129, 0.3);
}

/* 底部按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 16rpx;
  z-index: 100;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.action-btn::after {
  border: none;
}

.secondary-btn {
  background: #f1f5f9;
  color: #475569;
}

.secondary-btn:active {
  background: #e2e8f0;
}

.primary-btn {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.3);
}

.primary-btn:active {
  transform: scale(0.98);
}

.generate-btn {
  background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(139, 92, 246, 0.3);
}

.generate-btn:active {
  transform: scale(0.98);
}

.generate-btn[disabled] {
  opacity: 0.6;
}
