<!-- 训练记录页面 -->
<view class="container">
  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stats-header">
      <text class="stats-title">训练统计</text>
      <text class="stats-date">{{selectedDate}}</text>
    </view>
    <view class="stats-content">
      <view class="stat-item">
        <text class="stat-value">{{recordCount}}</text>
        <text class="stat-label">次数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{totalDuration}}</text>
        <text class="stat-label">总时长(秒)</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{totalCalories}}</text>
        <text class="stat-label">总消耗(千卡)</text>
      </view>
    </view>
  </view>

  <!-- 筛选区域 -->
  <view class="filter-section">
    <!-- 日期选择 -->
    <view class="filter-item">
      <text class="filter-label">日期</text>
      <picker mode="date" value="{{selectedDate}}" bindchange="selectDate">
        <view class="filter-value">
          <text>{{selectedDate}}</text>
          <text class="filter-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 类型选择 -->
    <view class="filter-item">
      <text class="filter-label">类型</text>
      <view class="type-filter">
        <view 
          wx:for="{{exerciseTypes}}" 
          wx:key="type" 
          class="type-item {{selectedType === item.type ? 'active' : ''}}"
          data-type="{{item.type}}"
          bindtap="selectType"
        >
          {{item.name}}
        </view>
      </view>
    </view>
  </view>

  <!-- 自定义训练计划切换 -->
  <view class="custom-plans-toggle" bindtap="toggleCustomPlans">
    <text class="toggle-title">自定义训练计划</text>
    <view class="toggle-right">
      <text class="toggle-count">{{customPlans.length}}个</text>
      <text class="toggle-icon">{{showCustomPlans ? '▲' : '▼'}}</text>
    </view>
  </view>

  <!-- 自定义训练计划列表 -->
  <view class="custom-plans-section" wx:if="{{showCustomPlans}}">
    <view class="section-header">
      <text class="section-title">我的训练计划</text>
      <button class="add-plan-btn" bindtap="goToCustomPlans">添加计划</button>
    </view>

    <view wx:if="{{customPlans.length > 0}}" class="custom-plans-list">
      <view 
        wx:for="{{customPlans}}" 
        wx:key="id" 
        class="custom-plan-card"
      >
        <view class="plan-header">
          <view class="plan-title">{{item.title}}</view>
          <view class="plan-category">{{item.category}}</view>
        </view>
        
        <view class="plan-exercises">
          <view class="exercise-item" wx:for="{{item.exercises}}" wx:for-item="exercise" wx:key="id">
            <view class="exercise-checkbox" bindtap="toggleExerciseComplete" data-plan-id="{{item.id}}" data-exercise-id="{{exercise.id}}">
              <checkbox checked="{{exercise.completed}}" disabled></checkbox>
            </view>
            <view class="exercise-content">
              <text class="exercise-name">{{exercise.name}}</text>
              <text class="exercise-details">{{exercise.sets}}组 × 间歇{{exercise.restTime}}秒</text>
            </view>
          </view>
        </view>
        
        <view class="plan-actions">
          <button 
            class="delete-btn" 
            data-id="{{item.id}}"
            bindtap="deleteCustomPlan"
          >删除计划</button>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <view class="empty-icon-emoji">📝</view>
      <text class="empty-text">暂无自定义训练计划</text>
      <text class="empty-tip">去训练页面创建你的第一个计划吧！</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="records-section">
    <view class="section-header">
      <text class="section-title">训练记录</text>
      <button class="export-btn" bindtap="exportData">导出数据</button>
    </view>

    <view wx:if="{{trainingRecords.length > 0}}" class="records-list">
      <view 
        wx:for="{{trainingRecords}}" 
        wx:key="id" 
        class="record-card"
      >
        <view class="record-header">
          <view class="record-type">
            <text class="type-icon">{{item.typeIcon}}</text>
            <text class="type-name">{{item.typeName}}</text>
          </view>
          <view class="record-time">{{item.time}}</view>
        </view>
        
        <view class="record-content">
          <view class="record-detail">
            <text class="detail-label">时长</text>
            <text class="detail-value">{{item.formatTime}}</text>
          </view>
          <view class="record-detail">
            <text class="detail-label">消耗</text>
            <text class="detail-value">{{item.calories}}千卡</text>
          </view>
          <view class="record-detail">
            <text class="detail-label">日期</text>
            <text class="detail-value">{{item.date}}</text>
          </view>
        </view>
        
        <view class="record-actions">
          <button 
            class="delete-btn" 
            data-id="{{item.id}}"
            bindtap="deleteRecord"
          >删除</button>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <view class="empty-icon-emoji">📋</view>
      <text class="empty-text">暂无训练记录</text>
      <text class="empty-tip">开始你的第一次训练吧！</text>
    </view>
  </view>
</view>