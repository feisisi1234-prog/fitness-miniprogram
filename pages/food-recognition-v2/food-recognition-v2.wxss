/* pages/food-recognition-v2/food-recognition-v2.wxss - 清新活力风格 */
page {
  background: linear-gradient(180deg, #f0f9ff 0%, #fef3f2 100%);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  position: relative;
}

/* 背景装饰 */
.bg-decoration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.gradient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.4;
  animation: float 20s ease-in-out infinite;
}

.orb-1 {
  width: 500rpx;
  height: 500rpx;
  background: linear-gradient(135deg, #a7f3d0, #6ee7b7);
  top: -150rpx;
  right: -100rpx;
}

.orb-2 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #fbbf24, #fb923c);
  bottom: 20%;
  left: -100rpx;
  animation-delay: -5s;
}

.orb-3 {
  width: 350rpx;
  height: 350rpx;
  background: linear-gradient(135deg, #93c5fd, #60a5fa);
  top: 40%;
  right: -80rpx;
  animation-delay: -10s;
}

@keyframes float {
  0%, 100% {
    transform: translate(0, 0) scale(1);
  }
  33% {
    transform: translate(30rpx, -30rpx) scale(1.1);
  }
  66% {
    transform: translate(-20rpx, 20rpx) scale(0.9);
  }
}

/* 上传区域 */
.upload-area {
  margin-top: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 120rpx 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  border: 3rpx dashed rgba(16, 185, 129, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: uploadFadeIn 0.6s ease;
  position: relative;
  z-index: 1;
}

@keyframes uploadFadeIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.upload-area:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
  border-color: rgba(16, 185, 129, 0.5);
}

.upload-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
  animation: floatIcon 3s ease-in-out infinite;
}

@keyframes floatIcon {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.upload-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.upload-hint {
  font-size: 26rpx;
  color: #64748b;
}

/* 预览区域 */
.preview-area {
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
  animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.preview-image {
  width: 100%;
  height: 500rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.action-btn {
  flex: 1;
  height: 90rpx;
  border-radius: 45rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  border: none;
}

.reselect-btn {
  background: #ffffff;
  color: #64748b;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.reselect-btn:active {
  transform: scale(0.95);
  background: #f1f5f9;
}

.recognize-btn {
  background: linear-gradient(135deg, #10b981, #059669);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.recognize-btn:active {
  transform: scale(0.95);
}

.recognize-btn[disabled] {
  opacity: 0.6;
}

/* 识别结果区域 */
.result-area {
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
  animation: fadeIn 0.5s ease;
}

.result-image-wrapper {
  margin-bottom: 30rpx;
}

.result-image {
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.result-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
}

.result-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #10b981, #059669);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.result-badge {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #10b981, #059669);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.result-item {
  margin-bottom: 24rpx;
}

.result-label {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.result-value {
  font-size: 30rpx;
  color: #0f172a;
  line-height: 1.6;
}

.name-value {
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #10b981, #059669);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.result-divider {
  height: 1rpx;
  background: #f1f5f9;
  margin: 30rpx 0;
}

.result-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.result-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.result-grid-item:active {
  transform: scale(0.95);
  background: #f1f5f9;
}

.grid-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 12rpx;
  opacity: 0.8;
}

.grid-label {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
  text-align: center;
}

.grid-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #10b981;
}

.label-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.suggestion-item {
  background: rgba(245, 158, 11, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 0;
  border-left: 4rpx solid #f59e0b;
}

.suggestion-value {
  line-height: 1.8;
  color: #334155;
}

.bottom-actions {
  margin-top: 30rpx;
}

.bottom-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #ffffff;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
  transition: all 0.3s ease;
}

.bottom-btn:active {
  transform: scale(0.95);
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-content {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(16, 185, 129, 0.2);
  border-top-color: #10b981;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.loading-hint {
  font-size: 26rpx;
  color: #64748b;
}
