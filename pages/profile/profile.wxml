<!--profile.wtml-->
<view class="page-container">
  <!-- 用户信息卡片 -->
  <view class="user-card card">
    <view class="user-info">
      <view class="avatar-section">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image src="{{userInfo.avatar || '/images/ui/placeholder.png'}}" class="user-avatar"></image>
        </button>
      </view>
      <view class="user-details">
        <view class="name-row">
          <text class="user-name">{{userInfo.name || '健身达人'}}</text>
          <view class="edit-profile-btn" bindtap="editProfile">
            <text class="edit-profile-text">编辑</text>
          </view>
        </view>
        <text class="user-level">{{userInfo.level || 'Lv.1 新手'}}</text>
        <view class="user-stats">
          <view class="stat-item">
            <text class="stat-number">{{userStats.totalDays}}</text>
            <text class="stat-label">训练天数</text>
          </view>
          <view class="stat-item">
            <text class="stat-number">{{userStats.continuousDays}}</text>
            <text class="stat-label">连续天数</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 本周卡路里消耗图表 -->
  <view class="chart-card card">
    <view class="chart-header">
      <text class="chart-title">本周卡路里消耗</text>
      <text class="chart-total">总计: {{weeklyCalories}}千卡</text>
    </view>
    <view class="chart-container">
      <view class="chart-bars">
        <view class="bar-item" wx:for="{{weeklyData}}" wx:key="day">
          <view class="bar-wrapper">
            <view class="bar-fill" style="height: {{item.percentage}}%"></view>
            <text class="bar-value">{{item.calories}}</text>
          </view>
          <text class="bar-label">{{item.day}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 日历组件 -->
  <view class="calendar-card card">
    <!-- 标题 -->
    <view class="calendar-title-section">
      <text class="calendar-title">训练日历</text>
    </view>
    
    <!-- 日期导航 -->
    <view class="calendar-header">
      <button class="nav-btn" bindtap="prevMonth">‹</button>
      <text class="current-month">{{currentYear}}年{{currentMonth}}月</text>
      <button class="nav-btn" bindtap="nextMonth">›</button>
    </view>
    
    <view class="calendar-grid">
      <!-- 星期标题 -->
      <view class="weekday-header">
        <text class="weekday-item">日</text>
        <text class="weekday-item">一</text>
        <text class="weekday-item">二</text>
        <text class="weekday-item">三</text>
        <text class="weekday-item">四</text>
        <text class="weekday-item">五</text>
        <text class="weekday-item">六</text>
      </view>
      
      <!-- 日期网格 -->
      <view class="calendar-days">
        <view class="day-item {{item.isCurrentMonth ? '' : 'other-month'}} {{item.isToday ? 'today' : ''}} {{item.hasTraining ? 'has-training' : ''}}" 
              wx:for="{{calendarDays}}" 
              wx:key="date"
              bindtap="selectDate"
              data-date="{{item.date}}">
          <text class="day-number">{{item.day}}</text>
          <view class="training-indicator" wx:if="{{item.hasTraining}}">
            <text class="indicator-dot"></text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToRecords">
      <view class="menu-icon-wrapper">
        <image src="/images/icons/chart.svg" class="menu-icon-img" mode="aspectFit"></image>
      </view>
      <view class="menu-content">
        <text class="menu-title">训练记录</text>
        <text class="menu-desc">查看详细训练历史</text>
      </view>
      <image src="/images/icons/arrow-right.svg" class="menu-arrow-img" mode="aspectFit"></image>
    </view>
    
    <view class="menu-item" bindtap="goToSettings">
      <view class="menu-icon-wrapper settings">
        <image src="/images/icons/settings.svg" class="menu-icon-img" mode="aspectFit"></image>
      </view>
      <view class="menu-content">
        <text class="menu-title">设置</text>
        <text class="menu-desc">个人信息和偏好设置</text>
      </view>
      <image src="/images/icons/arrow-right.svg" class="menu-arrow-img" mode="aspectFit"></image>
    </view>
    
    <view class="menu-item" bindtap="goToAbout">
      <view class="menu-icon-wrapper info">
        <image src="/images/icons/info.svg" class="menu-icon-img" mode="aspectFit"></image>
      </view>
      <view class="menu-content">
        <text class="menu-title">关于</text>
        <text class="menu-desc">应用信息和帮助</text>
      </view>
      <image src="/images/icons/arrow-right.svg" class="menu-arrow-img" mode="aspectFit"></image>
    </view>
  </view>
</view>