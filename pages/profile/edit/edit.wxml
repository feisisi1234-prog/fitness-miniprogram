<!--edit.wxml-->
<view class="container">
  <view class="header">
    <view class="title">编辑个人信息</view>
  </view>
  
  <view class="form-section">
    <view class="form-item">
      <view class="form-label">头像</view>
      <view class="avatar-container" bindtap="changeAvatar">
        <image class="avatar-img" src="{{userInfo.avatar || '/images/placeholder.png'}}" mode="aspectFill"></image>
        <view class="edit-icon">📷</view>
      </view>
    </view>
    
    <view class="form-item">
      <view class="form-label">昵称</view>
      <input class="form-input" placeholder="请输入昵称" value="{{userInfo.name}}" bindinput="onNameInput" />
    </view>
    
    <view class="form-item">
      <view class="form-label">性别</view>
      <view class="gender-options">
        <view class="gender-option {{userInfo.gender === 'male' ? 'active' : ''}}" data-gender="male" bindtap="onGenderChange">
          <text class="gender-icon">♂</text>
          <text>男性</text>
        </view>
        <view class="gender-option {{userInfo.gender === 'female' ? 'active' : ''}}" data-gender="female" bindtap="onGenderChange">
          <text class="gender-icon">♀</text>
          <text>女性</text>
        </view>
        <view class="gender-option {{userInfo.gender === '' ? 'active' : ''}}" data-gender="" bindtap="onGenderChange">
          <text class="gender-icon">⚥</text>
          <text>未设置</text>
        </view>
      </view>
    </view>
    
    <view class="form-item">
      <view class="form-label">身高</view>
      <view class="input-with-unit">
        <input class="form-input" placeholder="请输入身高" type="number" value="{{userInfo.height}}" bindinput="onHeightInput" />
        <text class="unit">cm</text>
      </view>
    </view>
    
    <view class="form-item">
      <view class="form-label">体重</view>
      <view class="input-with-unit">
        <input class="form-input" placeholder="请输入体重" type="number" value="{{userInfo.weight}}" bindinput="onWeightInput" />
        <text class="unit">kg</text>
      </view>
    </view>
    
    <view class="form-item">
      <view class="form-label">手机号</view>
      <input class="form-input" placeholder="请输入手机号" type="number" value="{{userInfo.phone}}" bindinput="onPhoneInput" />
    </view>
  </view>
  
  <view class="button-section">
    <button class="save-btn" bindtap="saveProfile">保存</button>
  </view>
</view>