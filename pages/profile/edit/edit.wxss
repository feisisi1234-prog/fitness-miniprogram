/**edit.wxss**/
page {
  height: 100vh;
  background: #fafafa;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  margin-bottom: 32rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  margin-top: 32rpx;
  margin-bottom: 8rpx;
  letter-spacing: -0.5rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 400;
}

.form-section {
  flex: 1;
}

.form-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-label {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: #1e293b;
  border: 2rpx solid #f1f5f9;
  border-radius: 14rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #f8fafc;
  transition: all 0.2s ease;
}

.form-input:focus {
  border-color: #10b981;
  background: #ffffff;
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
  width: 100%;
}

.avatar-btn::after {
  border: none;
}

.avatar-container {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 4rpx solid #f1f5f9;
}

.avatar-edit-overlay {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: #10b981;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
  border: 3rpx solid #ffffff;
}

.avatar-edit-icon {
  width: 20rpx;
  height: 20rpx;
}

.gender-options {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.gender-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  border-radius: 14rpx;
  border: 2rpx solid #f1f5f9;
  background: #f8fafc;
  transition: all 0.2s ease;
}

.gender-option.active {
  border-color: #10b981;
  background: #f0fdf4;
}

.gender-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.gender-icon-wrapper.male {
  background: #dbeafe;
}

.gender-icon-wrapper.female {
  background: #fce7f3;
}

.gender-icon-wrapper.other {
  background: #f3e8ff;
}

.gender-symbol {
  font-size: 32rpx;
  color: #1e293b;
}

.gender-text {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

.gender-option.active .gender-text {
  color: #10b981;
  font-weight: 600;
}

.input-with-unit {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input-with-unit .form-input {
  flex: 1;
}

.unit {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
}

.button-section {
  margin-top: 32rpx;
  padding-bottom: 40rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #10b981, #059669);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
  transition: all 0.2s ease;
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}