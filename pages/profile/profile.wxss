/**profile.wxss**/
.page-container {
  min-height: 100vh;
  background: #fafafa;
  padding: 20rpx;
  padding-bottom: 100rpx;
}

/* 用户信息卡片 - 优化版 */
.user-card {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
  padding: 36rpx 32rpx;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.25);
}

.user-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.user-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 2;
  gap: 24rpx;
}

.avatar-section {
  position: relative;
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
  position: relative;
}

.avatar-btn::after {
  border: none;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  object-fit: cover;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.user-details {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.user-name {
  font-size: 42rpx;
  font-weight: 700;
  color: #2d3748;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
  letter-spacing: -0.5rpx;
}

.edit-profile-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 18rpx;
  backdrop-filter: blur(10rpx);
  transition: all 0.2s ease;
}

.edit-profile-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.96);
}

.edit-profile-text {
  font-size: 26rpx;
  color: #2d3748;
  font-weight: 600;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.user-level {
  font-size: 28rpx;
  margin-bottom: 20rpx;
  display: block;
  color: #4a5568;
  font-weight: 500;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.user-stats {
  display: flex;
  gap: 32rpx;
}

.stat-item {
  text-align: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 4rpx;
  color: #2d3748;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.stat-label {
  font-size: 26rpx;
  display: block;
  color: #4a5568;
  font-weight: 500;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

/* 图表卡片 - 优化版 */
.chart-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.chart-total {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
}

.chart-container {
  height: 280rpx;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 240rpx;
  gap: 8rpx;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-wrapper {
  width: 100%;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  position: relative;
}

.bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #10b981 0%, #059669 100%);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 8rpx;
  transition: height 0.3s ease;
  position: relative;
}

.bar-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 8rpx 8rpx 0 0;
}

.bar-value {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
  font-weight: 500;
}

.bar-label {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 12rpx;
  font-weight: 400;
}

/* 图表卡片 */
.chart-card {
  margin-bottom: 30rpx;
  background-color: #ffffff;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.chart-total {
  font-size: 26rpx;
  color: #ff9500;
  font-weight: bold;
}

.chart-container {
  height: 200rpx;
  padding: 20rpx 0;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  height: 100%;
  gap: 10rpx;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}

.bar-wrapper {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  position: relative;
  margin-bottom: 10rpx;
}

.bar-fill {
  width: 80%;
  background: linear-gradient(180deg, #ff9500, #e6850e);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 4rpx;
  transition: height 0.5s ease;
  position: relative;
}

.bar-value {
  position: absolute;
  top: -25rpx;
  font-size: 20rpx;
  color: #666666;
  font-weight: bold;
}

.bar-label {
  font-size: 22rpx;
  color: #999999;
}

/* 日历卡片 */
.calendar-card {
  margin-bottom: 30rpx;
  background-color: #ffffff;
  padding: 30rpx 0rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.calendar-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
  padding: 0 20rpx;
}

.calendar-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  text-align: center;
  letter-spacing: 2rpx;
}

.calendar-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  gap: 30rpx;
}

.nav-btn {
  width: 40rpx;
  height: 30rpx;
  border-radius: 15rpx;
  background-color: #f5f7fa;
  border: 1rpx solid #e0e0e0;
  font-size: 22rpx;
  color: #666666;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  flex-shrink: 0;
  line-height: 1;
  font-weight: bold;
}

.nav-btn:first-child {
  left: auto;
}

.nav-btn:last-child {
  right: auto;
}

.nav-btn::after {
  border: none;
}

.nav-btn:active {
  background-color: rgba(7, 193, 96, 0.15);
  color: #07c160;
  border-color: #07c160;
}

.current-month {
  font-size: 28rpx;
  font-weight: bold;
  color: #07c160;
  text-align: center;
  letter-spacing: 1rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.calendar-grid {
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #eaeaea;
  margin: 0 20rpx;
}

.weekday-header {
  display: flex;
  background-color: #f0f2f5;
}

.weekday-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: #666666;
  font-weight: bold;
  width: calc(100% / 7);
  box-sizing: border-box;
}

.calendar-days {
  display: flex;
  flex-wrap: wrap;
  background-color: #ffffff;
}

.day-item {
  width: calc(100% / 7);
  height: 90rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #eaeaea;
  border-bottom: 1rpx solid #eaeaea;
  background-color: #ffffff;
  position: relative;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

/* 移除每行最后一个的右边框 */
.day-item:nth-child(7n) {
  border-right: none;
}

/* 移除最后一行的下边框 */
.day-item:nth-last-child(-n+7) {
  border-bottom: none;
}

.day-item:active {
  background-color: rgba(7, 193, 96, 0.1);
}

.day-item.other-month {
  opacity: 0.3;
  background-color: #fafafa;
}

.day-item.other-month .day-number {
  color: #999999;
}

.day-item.today {
  background-color: #07c160;
}

.day-item.today .day-number {
  color: #ffffff;
  font-weight: bold;
}

.day-item.has-training {
  background-color: rgba(7, 193, 96, 0.08);
}

.day-item.has-training.today {
  background-color: #07c160;
}

.day-number {
  font-size: 28rpx;
  color: #333333;
  line-height: 1;
}

.training-indicator {
  position: absolute;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
}

.indicator-dot {
  width: 6rpx;
  height: 6rpx;
  background-color: #07c160;
  border-radius: 50%;
  display: block;
}

.day-item.today .indicator-dot {
  background-color: #ffffff;
}

.day-item.other-month .indicator-dot {
  opacity: 0.5;
}

/* 功能菜单 */
.menu-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eaeaea;
  transition: all 0.3s ease;
}

.menu-item:active {
  background-color: #f0f2f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #007aff, #0066cc);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #666666;
  display: block;
}

.menu-arrow {
  font-size: 32rpx;
  color: #999999;
}

