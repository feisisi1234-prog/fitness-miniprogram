/* 通用卡片样式 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}


/* 用户ID */
.user-id-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 12rpx;
  width: fit-content;
  max-width: 100%;
  backdrop-filter: blur(10rpx);
}

.user-id-label {
  font-size: 24rpx;
  color: #1e293b;
  font-weight: 500;
  flex-shrink: 0;
}

.user-id {
  font-size: 24rpx;
  color: #1e293b;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  font-family: 'Courier New', monospace;
  word-break: break-all;
  flex: 1;
  min-width: 0;
}

.user-level {
  font-size: 26rpx;
  color: #334155;
  margin-bottom: 16rpx;
  font-weight: 500;
}
