/**profile.wxss**/
page {
  overflow-x: hidden;
  width: 100%;
  height: 100%;
}

.page-container {
  min-height: 100vh;
  background: #fafafa;
  padding: 20rpx;
  padding-bottom: 100rpx;
  overflow-x: hidden;
  width: 100%;
  box-sizing: border-box;
}

/* 用户信息卡片 - 优化版 */
.user-card {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
  padding: 36rpx 24rpx;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.25);
}

.user-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.user-info {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  position: relative;
  z-index: 2;
  gap: 20rpx;
}

.avatar-section {
  position: relative;
  flex-shrink: 0;
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
  position: relative;
}

.avatar-btn::after {
  border: none;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  border: 4rpx solid rgba(0, 0, 0, 0.8);
  object-fit: cover;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.user-details {
  flex: 1;
  min-width: 0;
  padding-top: 4rpx;
}

.name-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 10rpx;
  gap: 12rpx;
  flex-wrap: wrap;
}

.user-name {
  font-size: 42rpx;
  font-weight: 700;
  color: #1e293b;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
  letter-spacing: -0.5rpx;
  flex: 0 0 auto;
}

.edit-profile-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.edit-profile-btn:active {
  background: rgba(255, 255, 255, 1);
  transform: scale(0.96);
}

.edit-profile-text {
  font-size: 26rpx;
  color: #10b981;
  font-weight: 600;
}

.user-level {
  font-size: 28rpx;
  margin-bottom: 20rpx;
  display: block;
  color: #334155;
  font-weight: 500;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.user-stats {
  display: flex;
  gap: 32rpx;
}

.stat-item {
  text-align: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 4rpx;
  color: #1e293b;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.stat-label {
  font-size: 26rpx;
  display: block;
  color: #475569;
  font-weight: 500;
}

/* 图表卡片 - 优化版 */
.chart-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.chart-total {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
}

.chart-container {
  height: 280rpx;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 240rpx;
  gap: 8rpx;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-wrapper {
  width: 100%;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  position: relative;
}

.bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #10b981 0%, #059669 100%);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 8rpx;
  transition: height 0.3s ease;
  position: relative;
}

.bar-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 8rpx 8rpx 0 0;
}

.bar-value {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
  font-weight: 500;
}

.bar-label {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 12rpx;
  font-weight: 400;
}

/* 图表卡片 */
.chart-card {
  margin-bottom: 30rpx;
  background-color: #ffffff;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.chart-total {
  font-size: 26rpx;
  color: #ff9500;
  font-weight: bold;
}

.chart-container {
  height: 200rpx;
  padding: 20rpx 0;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  height: 100%;
  gap: 10rpx;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}

.bar-wrapper {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  position: relative;
  margin-bottom: 10rpx;
}

.bar-fill {
  width: 80%;
  background: linear-gradient(180deg, #ff9500, #e6850e);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 4rpx;
  transition: height 0.5s ease;
  position: relative;
}

.bar-value {
  position: absolute;
  top: -25rpx;
  font-size: 20rpx;
  color: #666666;
  font-weight: bold;
}

.bar-label {
  font-size: 22rpx;
  color: #999999;
}

/* 日历卡片 - 统一优化版 */
.calendar-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 标题区域 */
.calendar-title-section {
  text-align: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.calendar-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  letter-spacing: 2rpx;
}

/* 日期导航区域 */
.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
  gap: 8rpx;
  min-height: 48rpx;
}

.nav-btn {
  width: 44rpx;
  height: 44rpx;
  background: #f8fafc;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #64748b;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 44rpx;
  transition: all 0.2s ease;
  font-weight: bold;
  flex-shrink: 0;
}

.nav-btn::after {
  border: none;
}

.nav-btn:active {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  transform: scale(0.95);
}

.current-month {
  flex: 1;
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 600;
  text-align: center;
  white-space: nowrap;
  line-height: 44rpx;
}

.calendar-grid {
  margin-top: 20rpx;
  padding: 0 8rpx;
}

.weekday-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.weekday-item {
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
  font-weight: 500;
  padding: 12rpx 0;
}

.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
}

.day-item {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  position: relative;
  transition: all 0.2s ease;
  background: #f8fafc;
  min-height: 80rpx;
}

.day-item.other-month {
  opacity: 0.3;
  background: #fafafa;
}

.day-item.today {
  background: #f0fdf4;
  border: 2rpx solid #10b981;
}

.day-item.has-training {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.day-item.has-training .day-number {
  color: #ffffff;
  font-weight: 600;
}

.day-item.today.has-training {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border: 2rpx solid #047857;
}

.day-item:active {
  transform: scale(0.95);
}

.day-number {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
  line-height: 1;
}

.training-indicator {
  position: absolute;
  bottom: 8rpx;
  width: 100%;
  display: flex;
  justify-content: center;
}

.indicator-dot {
  width: 6rpx;
  height: 6rpx;
  background: #ffffff;
  border-radius: 50%;
  display: block;
}

/* 功能菜单 */
.menu-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eaeaea;
  transition: all 0.3s ease;
}

.menu-item:active {
  background-color: #f0f2f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #007aff, #0066cc);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #666666;
  display: block;
}

.menu-arrow {
  font-size: 32rpx;
  color: #999999;
}



